<?xml version="1.0"?>
<ruleset name="VigieChiro Companion - garde-fous de conception"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>
        Garde-fous de conception du produit. Chaque règle pointe un smell et suggère
        le refactoring correspondant (Fowler, Refactoring, 2e éd.) : méthode trop
        longue -> Extract Method, classe trop grosse -> Extract Class, liste de
        paramètres -> Introduce Parameter Object.

        Les seuils ne sont pas les valeurs par défaut de PMD. Chacun a été relevé
        au vu d'un code précis, nommé dans le commentaire de la règle : sans cette
        trace, un seuil finit par protéger une situation qui n'existe plus. Les
        modifier suppose donc de rouvrir la justification, pas seulement le chiffre.

        Revérifier les chiffres cités : rejouer les mêmes règles avec leurs seuils
        au plancher (methodReportLevel et classReportLevel à 1), depuis un pom
        jetable hors dépôt pointant sur src/main/java, puis lire les métriques dans
        target/pmd.xml. Attention, -Dpmd.rulesets n'existe pas comme propriété
        utilisateur : la passer laisse le ruleset du pom en place et produit un
        rapport qui ressemble à un succès.

        Usage :
          ./mvnw verify           # PMD en warning, ne bloque pas
          ./mvnw pmd:check        # rapport console seul
          ./mvnw pmd:pmd          # rapport HTML (target/site/pmd.html)
          ./mvnw -Pquality-gate verify   # PMD bloque (portail qualité, lint.yml)

        Une violation se corrige, elle ne se tait pas : ni @SuppressWarnings("PMD...")
        ni //NOPMD. Si un seuil est vraiment inadapté, c'est le seuil qu'on rediscute
        ici, avec sa justification.
    </description>

    <!-- ============================================================
         LONG METHOD -> Extract Method
         ============================================================ -->

    <rule ref="category/java/design.xml/NcssCount">
        <properties>
            <!-- 50 lignes de code non-comment effectif. Les mêmes parseurs/lecteurs
                 déterministes que ceux tolérés par CyclomaticComplexity sont aussi
                 longs par nature (balayage caractère par caractère) : lecteur CSV de
                 commun/** (gelé, 44), lecteur de tableau JSON (45), parseur LogPR (45).
                 50 les couvre sans découpage artificiel d'une logique cohésive ;
                 plus bas pénaliserait du code d'infrastructure, plus haut serait laxiste.
                 ⚠ Ce n'est plus un parseur qui approche le plafond, mais
                 MoteurImport.importerUneNuit, à 49. La marge est d'une ligne : l'y
                 ajouter fera rougir lint.yml. Constaté et assumé, pas un oubli. -->
            <property name="methodReportLevel" value="50"/>
            <!-- 200 lignes par classe = God Class détectable en dernier recours,
                 avant même que GodClass ne s'active.
                 ⚠ Quatre contrôleurs vivent dans les huit derniers points :
                 SonsValidationController 199, AnalyseController et LotController 197,
                 ImportationController 193. Le prochain ajout dans l'un d'eux demandera
                 un Extract Class, pas un relèvement du seuil. -->
            <property name="classReportLevel" value="200"/>
        </properties>
    </rule>

    <!-- ============================================================
         LONG PARAMETER LIST -> Introduce Parameter Object
         ============================================================ -->

    <rule ref="category/java/design.xml/ExcessiveParameterList">
        <properties>
            <!-- Seuil relevé de 10 (défaut PMD) à 11. Les services métier, leurs
                 méthodes @Provides Guice et les contrôleurs agrègent légitimement
                 plusieurs DAO/collaborateurs par injection de dépendances. Quatre
                 sites sont à 11 et justifient à eux seuls ce point d'écart :
                 ServiceValidation, son @Provides miroir dans ValidationModule,
                 AudioViewModel et SonsValidationController. Un param-objet y nuirait
                 à la clarté : c'est inhérent à la DI, pas un smell.
                 11 reste un garde-fou : au-delà, un Parameter Object est attendu. -->
            <property name="minimum" value="11"/>
        </properties>
    </rule>

    <!-- ============================================================
         CYCLOMATIC COMPLEXITY -> Extract Method / Polymorphisme
         ============================================================ -->

    <rule ref="category/java/design.xml/CyclomaticComplexity">
        <properties>
            <!-- Seuil 24 (au-dessus du défaut PMD 10). Les parseurs déterministes
                 écrits à la main (sans dépendance tierce) sont intrinsèquement
                 branchus : le lecteur de tableau JSON (LectureJsonTableau, switch
                 d'échappement) atteint 23, l'en-tête WAV (FichierWav.analyser) 22,
                 le parseur de log LogPR 16, le lecteur CSV de commun/** (gelé) 15.
                 Ce sont des machines à états cohésives, pas des smells à découper.
                 24 laisse passer ces parseurs tout en gardant un garde-fou. -->
            <property name="methodReportLevel" value="24"/>
            <property name="classReportLevel" value="80"/>
        </properties>
    </rule>

    <!-- ============================================================
         DEEPLY NESTED IFS -> Early return / Guard clauses
         ============================================================ -->

    <rule ref="category/java/design.xml/AvoidDeeplyNestedIfStmts">
        <properties>
            <!-- 3 niveaux d'imbrication, la valeur par défaut de PMD. Le seuil a été
                 tenu à 4 pour un unique site, la détection de batterie faible
                 d'AnalyseurLogPR, depuis réécrite en clauses gardes. Plus aucun code
                 ne réclame de tolérance ici : au-delà de deux niveaux, une clause
                 garde ou une extraction de méthode se lit mieux que l'imbrication.
                 La valeur est écrite explicitement pour la figer si le défaut de PMD
                 venait à bouger. -->
            <property name="problemDepth" value="3"/>
        </properties>
    </rule>

    <!-- ============================================================
         GOD CLASS -> Extract Class
         ============================================================ -->

    <rule ref="category/java/design.xml/GodClass"/>

    <!-- ============================================================
         MAGIC NUMBER / MAGIC STRING -> Replace with Symbolic Constant
         ============================================================ -->

    <rule ref="category/java/errorprone.xml/AvoidDuplicateLiterals">
        <properties>
            <!-- Un littéral dupliqué 3 fois ou plus déclenche un warning.
                 Les valeurs triviales (chaînes vides, indices, bornes) sont
                 autorisées car légitimement répétées partout. -->
            <property name="maxDuplicateLiterals" value="3"/>
            <property name="minimumLength" value="3"/>
            <property name="exceptionList" value="&quot;&quot;"/>
            <property name="skipAnnotations" value="true"/>
        </properties>
    </rule>

    <!-- ============================================================
         FEATURE ENVY ~ Switch Statement sur un type -> Polymorphisme
         Détection indirecte via une chaîne de if/else-if sur getClass()
         ou sur un champ type. Pas de règle PMD directe "feature envy" /
         "switch on type" ; la combinaison CyclomaticComplexity +
         AvoidDeeplyNestedIfStmts couvre le cas en pratique.
         ============================================================ -->

    <!-- ============================================================
         BEST PRACTICE : pas de réassignation de paramètre
         ============================================================ -->

    <rule ref="category/java/bestpractices.xml/AvoidReassigningParameters"/>

</ruleset>

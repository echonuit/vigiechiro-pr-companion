#!/bin/bash
# Pre-commit hook : formate automatiquement les fichiers Java stagés
# avec Spotless (Google Java Format).
#
# Installé automatiquement par git-build-hook-maven-plugin au premier
# ./mvnw exécuté dans le repo (qui configure core.hooksPath=.githooks).
#
# Comportement :
# - Skip si aucun fichier .java n'est stagé
# - Lance ./mvnw spotless:apply silencieusement (reformate tout le
#   working tree, pas seulement les hunks stagés)
# - Re-stage les fichiers Java qui étaient déjà stagés pour que le
#   reformatage entre dans le commit
# - Si Spotless échoue, le commit passe quand même (on ne veut pas
#   bloquer l'étudiant pour une question de format)
#
# Limitation connue : ce hook NE préserve PAS un `git add -p` partiel.
# Si un fichier a été partiellement stagé (certains hunks seulement),
# le `git add` final re-stage le fichier complet reformaté. Ce cas
# d'usage reste rare en BUT1 ; une version qui le gère proprement
# demanderait un stash/restore des hunks non stagés, trop fragile pour
# un hook silencieux.

set -e

# Protection : bloquer les commits sur main dans les repos ENSEIGNANT uniquement.
# Dans le repo enseignant (IUTInfoAix-R203), la branche main est dérivée de
# solution et régénérée par la CI. Un commit manuel serait écrasé.
# Dans les repos ÉTUDIANTS (IUTInfoAix-R203-2026), main est la seule branche
# et les étudiants doivent pouvoir y commiter normalement.
# Détection : si la branche "solution" existe localement, c'est un repo enseignant.
# Bypass : ALLOW_MAIN_COMMIT=1 git commit ... (utilisé par generate-student.sh)
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)
HAS_SOLUTION=$(git rev-parse --verify solution 2>/dev/null && echo "yes" || true)
if [ "$BRANCH" = "main" ] && [ "$HAS_SOLUTION" = "yes" ] && [ "$ALLOW_MAIN_COMMIT" != "1" ]; then
  echo ""
  echo "  ⛔  Commit bloqué : vous êtes sur la branche 'main' du repo enseignant."
  echo ""
  echo "  La branche main est la version étudiante, régénérée automatiquement"
  echo "  par la CI à chaque push sur 'solution'. Un commit manuel ici serait"
  echo "  écrasé au prochain push."
  echo ""
  echo "  → Pour travailler : git checkout solution"
  echo "  → Pour générer main : cd ../template-tp-java && ./generate-student.sh --apply ../\$(basename \"\$PWD\")"
  echo ""
  exit 1
fi
# Bloc TEACHER-LINT : injecté par Copier UNIQUEMENT si la feature
# lint-quality est active (sinon ./mvnw pmd:check et lint-doc-coherence
# n'existent pas dans le TP). Les linters tournent uniquement sur la
# branche 'solution' (donc côté enseignant), strippés automatiquement
# par generate-student.sh côté étudiant.
#
# Bypass d'urgence : SKIP_LINT=1 git commit ...
if [ "$BRANCH" = "solution" ] && [ "$HAS_SOLUTION" = "yes" ] && [ "${SKIP_LINT:-}" != "1" ]; then
  if [ -x scripts/lint-doc-coherence.sh ]; then
    if ! ./scripts/lint-doc-coherence.sh; then
      echo ""
      echo "  ⛔  Commit bloqué : incohérence documentaire détectée."
      echo "  → Corrige les points ci-dessus, ou bypass avec SKIP_LINT=1 git commit ..."
      echo ""
      exit 1
    fi
  fi

  if ! ./mvnw -q -Pquality-gate -DskipTests pmd:check 2>/dev/null; then
    echo ""
    echo "  ⛔  Commit bloqué : PMD a trouvé des code smells dans la solution."
    echo "  → Lance './mvnw pmd:check' pour voir le détail, ou bypass avec SKIP_LINT=1 git commit ..."
    echo ""
    exit 1
  fi
fi

# Liste des fichiers Java staged (Added / Copied / Modified)
STAGED_JAVA=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.java$' || true)
[ -z "$STAGED_JAVA" ] && exit 0

# Formate silencieusement
./mvnw -q spotless:apply >/dev/null 2>&1 || exit 0

# Re-stage uniquement les fichiers qui étaient déjà stagés
echo "$STAGED_JAVA" | xargs git add

exit 0

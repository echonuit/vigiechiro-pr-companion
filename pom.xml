<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>fr.univ_amu.iut</groupId>
    <artifactId>vigiechiro</artifactId>
    <name>SAÉ 2.01 - VigieChiro PR Companion</name>

    <packaging>jar</packaging>
    <version>1.0-SNAPSHOT</version>
    <url>https://github.com/IUTInfoAix-S201</url>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.release>25</maven.compiler.release>

        <maven.compiler.plugin.version>3.15.0</maven.compiler.plugin.version>
        <maven.surefire.plugin.version>3.5.6</maven.surefire.plugin.version>
        <maven.shade.plugin.version>3.6.2</maven.shade.plugin.version>
        <exec.maven.plugin.version>3.6.3</exec.maven.plugin.version>
        <spotless.maven.plugin.version>3.6.0</spotless.maven.plugin.version>
        <google.java.format.version>1.35.0</google.java.format.version>
        <git.build.hook.plugin.version>3.6.0</git.build.hook.plugin.version>
        <maven.pmd.plugin.version>3.28.0</maven.pmd.plugin.version>
        <javafx.version>26</javafx.version>
        <javafx.maven.plugin.version>0.0.8</javafx.maven.plugin.version>
        <testfx.version>4.0.18</testfx.version>

        <junit.jupiter.version>6.1.0</junit.jupiter.version>
        <assertj.version>3.27.7</assertj.version>
        <mockito.version>5.23.0</mockito.version>
        <approvaltests.version>30.1.1</approvaltests.version>
        <archunit.version>1.4.2</archunit.version>

        <!-- Persistance + injection de dépendances (cf. TP5 / TP4). -->
        <guice.version>7.0.0</guice.version>
        <sqlite.jdbc.version>3.49.1.0</sqlite.jdbc.version>

        <!-- Couverture (JaCoCo) + mutation (PIT, profil -Pmutation uniquement). -->
        <jacoco.version>0.8.14</jacoco.version>
        <pitest.version>1.25.2</pitest.version>
        <pitest.junit5.version>1.2.3</pitest.junit5.version>

        <!-- Rempli à la volée par jacoco:prepare-agent. Vide par défaut pour ne JAMAIS
             casser ./mvnw test (Surefire le réinjecte via @{jacocoArgLine}). -->
        <jacocoArgLine></jacocoArgLine>
    </properties>

    <!-- JitPack : dépôt du composant audio-view de la SAÉ 2.01 (boîte noire fournie). -->
    <repositories>
        <repository>
            <id>jitpack.io</id>
            <url>https://jitpack.io</url>
        </repository>
    </repositories>

    <dependencies>
        <dependency>
            <groupId>org.junit</groupId>
            <artifactId>junit-bom</artifactId>
            <version>${junit.jupiter.version}</version>
            <type>pom</type>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>${junit.jupiter.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <version>${assertj.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>com.approvaltests</groupId>
            <artifactId>approvaltests</artifactId>
            <version>${approvaltests.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-junit-jupiter</artifactId>
            <version>${mockito.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-fxml</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-graphics</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-media</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <!-- javafx-swing : SwingFXUtils pour la capture d'écran hors-écran (outil enseignant,
             cf. commun.outils.ApercuFx). Version alignée sur le reste de JavaFX. -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-swing</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <dependency>
            <groupId>org.testfx</groupId>
            <artifactId>testfx-core</artifactId>
            <version>${testfx.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testfx</groupId>
            <artifactId>testfx-junit5</artifactId>
            <version>${testfx.version}</version>
            <scope>test</scope>
        </dependency>

        <!-- Persistance JDBC : driver SQLite (module automatique org.xerial.sqlitejdbc). -->
        <dependency>
            <groupId>org.xerial</groupId>
            <artifactId>sqlite-jdbc</artifactId>
            <version>${sqlite.jdbc.version}</version>
        </dependency>

        <!-- Injection de dépendances (Guice 7), comme au TP4. -->
        <dependency>
            <groupId>com.google.inject</groupId>
            <artifactId>guice</artifactId>
            <version>${guice.version}</version>
        </dependency>

        <!-- Composant audio (sonogramme/spectrogramme) fourni pour la SAÉ, via JitPack. -->
        <dependency>
            <groupId>com.github.IUTInfoAix-S201</groupId>
            <artifactId>audio-view</artifactId>
            <version>v1.3.0</version>
        </dependency>

        <!-- ArchUnit : tests d'architecture (règles de couches / absence de cycles). -->
        <dependency>
            <groupId>com.tngtech.archunit</groupId>
            <artifactId>archunit-junit5</artifactId>
            <version>${archunit.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <includes>
                    <include>**/*</include>
                </includes>
            </resource>
            <!--
              Convention TP3 : les .fxml/.css de vue vivent À CÔTÉ de leur controller
              dans src/main/java/.../view/, sans naviguer entre src/main/java et
              src/main/resources. Tous les fichiers non-Java de src/main/java sont
              copiés dans target/classes au même chemin de paquetage (les ressources
              PARTAGÉES (db/migration, DarkTheme.css) restent dans src/main/resources).
            -->
            <resource>
                <directory>src/main/java</directory>
                <excludes>
                    <exclude>**/*.java</exclude>
                </excludes>
            </resource>
        </resources>

        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${maven.compiler.plugin.version}</version>
                <configuration>
                    <release>${maven.compiler.release}</release>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>${exec.maven.plugin.version}</version>
                <configuration>
                    <mainClass>fr.univ_amu.iut.App</mainClass>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>${maven.shade.plugin.version}</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals><goal>shade</goal></goals>
                        <configuration>
                            <transformers>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <mainClass>fr.univ_amu.iut.App</mainClass>
                                </transformer>
                            </transformers>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>${maven.surefire.plugin.version}</version>
                <configuration>
                    <!-- TestFX requires classpath mode (not module path) -->
                    <useModulePath>false</useModulePath>
                    <!-- Headless Platform JavaFX 26 (Gluon) : plateforme Glass logicielle, sans
                         natif ni serveur d'affichage. Aucune fenêtre TestFX/JavaFX n'apparaît à
                         l'écran, localement comme en CI, et plus besoin de xvfb. Le robot Glass
                         pilote la plateforme Headless, le pipeline de rendu logiciel (sw)
                         remplace le GPU. Remplace l'ancien bricolage Monocle.
                         NB : on NE met PAS testfx.headless=true : ce flag déclencherait le vieux
                         bootstrap Monocle de TestFX (recherche de MonoclePlatformFactory, classe
                         absente sans la dépendance monocle). Le headless vient ici de
                         glass.platform=Headless, pas de TestFX. -->
                    <systemPropertyVariables>
                        <glass.platform>Headless</glass.platform>
                        <prism.order>sw</prism.order>
                        <java.awt.headless>true</java.awt.headless>
                        <testfx.robot>glass</testfx.robot>
                    </systemPropertyVariables>
                    <argLine>
                        @{jacocoArgLine}
                        --enable-native-access=ALL-UNNAMED
                        --enable-native-access=javafx.graphics
                        --add-reads javafx.graphics=ALL-UNNAMED
                        --add-opens javafx.graphics/com.sun.javafx.application=ALL-UNNAMED
                        --add-opens javafx.base/com.sun.javafx.runtime=ALL-UNNAMED
                        --add-exports javafx.graphics/com.sun.javafx.application=ALL-UNNAMED
                        --add-exports javafx.graphics/com.sun.javafx.util=ALL-UNNAMED
                        --add-exports javafx.base/com.sun.javafx.logging=ALL-UNNAMED
                    </argLine>
                </configuration>
            </plugin>

            <!-- Spotless : formatage Google Java Format. Opt-in via
                 ./mvnw spotless:apply, déclenché par .githooks/pre-commit. -->
            <plugin>
                <groupId>com.diffplug.spotless</groupId>
                <artifactId>spotless-maven-plugin</artifactId>
                <version>${spotless.maven.plugin.version}</version>
                <configuration>
                    <java>
                        <googleJavaFormat>
                            <version>${google.java.format.version}</version>
                        </googleJavaFormat>
                        <removeUnusedImports/>
                        <trimTrailingWhitespace/>
                        <endWithNewline/>
                    </java>
                </configuration>
            </plugin>

            <!-- git-build-hook : configure silencieusement
                 core.hooksPath=.githooks au premier ./mvnw. -->
            <plugin>
                <groupId>com.rudikershaw.gitbuildhook</groupId>
                <artifactId>git-build-hook-maven-plugin</artifactId>
                <version>${git.build.hook.plugin.version}</version>
                <configuration>
                    <gitConfig>
                        <core.hooksPath>.githooks</core.hooksPath>
                    </gitConfig>
                </configuration>
                <executions>
                    <execution><goals><goal>configure</goal></goals></execution>
                </executions>
            </plugin>

            <!-- PMD : linter de code smells aligné sur les refactorings
                 enseignés. Ruleset pédagogique dans pmd-ruleset.xml.
                 Par défaut failOnViolation=false (warning only) ; le
                 profil -Pquality-gate active failOnViolation=true. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-pmd-plugin</artifactId>
                <version>${maven.pmd.plugin.version}</version>
                <configuration>
                    <rulesets>
                        <ruleset>${project.basedir}/pmd-ruleset.xml</ruleset>
                    </rulesets>
                    <printFailingErrors>true</printFailingErrors>
                    <failOnViolation>false</failOnViolation>
                    <linkXRef>false</linkXRef>
                    <targetJdk>25</targetJdk>
                    <includeTests>false</includeTests>
                </configuration>
                <executions>
                    <execution>
                        <id>pmd-check</id>
                        <phase>verify</phase>
                        <goals><goal>check</goal></goals>
                    </execution>
                </executions>
            </plugin>

            <!-- JaCoCo : couverture de tests. report + check NON bloquants pour
                 l'instant (aucun seuil ne casse le build sur un code partiel). On
                 durcira les seuils quand le coeur métier sera implémenté. -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>${jacoco.version}</version>
                <executions>
                    <execution>
                        <id>prepare-agent</id>
                        <goals><goal>prepare-agent</goal></goals>
                        <configuration>
                            <propertyName>jacocoArgLine</propertyName>
                        </configuration>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>test</phase>
                        <goals><goal>report</goal></goals>
                    </execution>
                    <execution>
                        <id>check</id>
                        <phase>verify</phase>
                        <goals><goal>check</goal></goals>
                        <configuration>
                            <haltOnFailure>false</haltOnFailure>
                            <rules>
                                <rule>
                                    <element>BUNDLE</element>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.00</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                            </rules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-maven-plugin</artifactId>
                <version>${javafx.maven.plugin.version}</version>
                <configuration>
                    <jlinkImageName>app</jlinkImageName>
                    <launcher>launcher</launcher>
                    <mainClass>tp1.javafx/fr.univ_amu.iut.App</mainClass>
                    <options>
                        <!-- Native access JavaFX (Java 25 strict). -->
                        <option>--enable-native-access=javafx.graphics</option>
                    </options>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- Profil mutation : PIT (org.pitest). NON exécuté par défaut.
             Lancer explicitement via ./mvnw -Pmutation test (lent). -->
        <profile>
            <id>mutation</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.pitest</groupId>
                        <artifactId>pitest-maven</artifactId>
                        <version>${pitest.version}</version>
                        <configuration>
                            <targetClasses>
                                <param>fr.univ_amu.iut.*</param>
                            </targetClasses>
                            <targetTests>
                                <param>fr.univ_amu.iut.*</param>
                            </targetTests>
                            <outputFormats>
                                <param>HTML</param>
                                <param>XML</param>
                            </outputFormats>
                            <timestampedReports>false</timestampedReports>
                        </configuration>
                        <dependencies>
                            <dependency>
                                <groupId>org.pitest</groupId>
                                <artifactId>pitest-junit5-plugin</artifactId>
                                <version>${pitest.junit5.version}</version>
                            </dependency>
                        </dependencies>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- Profil enseignant : PMD bloque sur violation. -->
        <profile>
            <id>quality-gate</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-pmd-plugin</artifactId>
                        <configuration>
                            <failOnViolation>true</failOnViolation>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>

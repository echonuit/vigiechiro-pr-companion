fr/univ_amu/iut/sites/view/ModalePoint.fxml              : apercu-sites-modale-point.png apercu-sites-modale-point-creation.png
fr/univ_amu/iut/importation/view/Importation.fxml        : apercu-import-assistant.png apercu-import-en-cours.png apercu-import-melange.png apercu-import-incoherence.png apercu-import-decompression.png apercu-import-rejets.png
fr/univ_amu/iut/qualification/view/Qualification.fxml    : apercu-qualification.png apercu-qualification-initial.png
fr/univ_amu/iut/passage/view/Passage.fxml                : apercu-passage.png apercu-passage-depose.png
fr/univ_amu/iut/passage/view/RattachementModale.fxml     : apercu-passage-rattachement.png
fr/univ_amu/iut/diagnostic/view/Diagnostic.fxml          : apercu-diagnostic.png apercu-diagnostic-sans-releve.png

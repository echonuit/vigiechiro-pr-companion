<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  Modale « Connexion VigieChiro » (#727/#741), ouverte depuis l'entrée « Connexion VigieChiro » du menu
  ☰ du chrome, dans un Stage modal applicatif. Guide en trois étapes : ouvrir VigieChiro, installer le
  marque-page qui copie le token, puis coller le token (vérifié via GET /moi). « Se déconnecter » efface
  la connexion locale. Câblée au ConnexionViewModel par ConnexionModaleController.
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:id="racine"
      fx:controller="fr.univ_amu.iut.connexion.view.ConnexionModaleController"
      stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css"
      prefWidth="560.0"
      spacing="16.0">

  <!-- Marges de la modale (le Stage n'en fournit aucune) : sans elles le contenu colle aux bords. -->
  <padding>
    <Insets top="24.0" right="28.0" bottom="22.0" left="28.0"/>
  </padding>

  <Label text="Connexion VigieChiro" styleClass="titre-page"/>
  <Label text="Reliez l'application à votre compte VigieChiro en trois étapes (aucun fichier à installer)."
         styleClass="section-sous" wrapText="true"/>

  <!-- Badge d'état : gris « Non connecté » / vert « Connecté : … ». styleClass pilotée par le controller. -->
  <Label fx:id="labelIdentite" styleClass="badge, badge-neutre"/>

  <!-- Étape 1 : ouvrir la plateforme -->
  <VBox spacing="4.0">
    <Label text="1 · Ouvrir la plateforme" styleClass="bandeau-label"/>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
      <Label text="Connectez-vous sur VigieChiro (GitHub ou Google)."
             wrapText="true" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
      <Button text="Ouvrir VigieChiro" styleClass="action-secondaire" onAction="#ouvrirSite"/>
    </HBox>
  </VBox>

  <!-- Étape 2 : installer le marque-page -->
  <VBox spacing="4.0">
    <Label text="2 · Installer le marque-page (une seule fois)" styleClass="bandeau-label"/>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
      <Label text="Copiez le marque-page, créez un favori et collez-le comme adresse."
             wrapText="true" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
      <Button text="Copier le marque-page" styleClass="action-secondaire" onAction="#copierMarquePage"/>
    </HBox>
  </VBox>

  <!-- Étape 3 : coller le token -->
  <VBox spacing="4.0">
    <Label text="3 · Coller le token" styleClass="bandeau-label"/>
    <Label text="Sur l'onglet VigieChiro connecté, cliquez le marque-page (il copie votre token), puis collez-le ici."
           styleClass="section-sous" wrapText="true"/>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
      <TextField fx:id="champToken" promptText="collez votre token ici" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
      <!-- Enveloppe : un Button désactivé n'affiche pas de Tooltip, on le pose sur ce StackPane (#789). -->
      <StackPane fx:id="enveloppeConnecter">
        <Button fx:id="boutonConnecter" text="Se connecter" styleClass="action-primaire" onAction="#connecter"/>
      </StackPane>
    </HBox>
  </VBox>

  <!-- Bandeau de feedback de l'action (succès/échec/hint) : masqué tant qu'il n'y a rien à dire ; sa
       styleClass sémantique (bandeau-statut + badge-succes/danger/info) est posée par le controller. -->
  <Label fx:id="bandeauStatut" styleClass="bandeau-statut" wrapText="true"
         maxWidth="Infinity" visible="false" managed="false"/>

  <HBox alignment="CENTER_RIGHT" spacing="8.0">
    <StackPane fx:id="enveloppeDeconnecter">
      <Button fx:id="boutonDeconnecter" text="Se déconnecter"
              styleClass="action-secondaire" onAction="#deconnecter"/>
    </StackPane>
    <Region HBox.hgrow="ALWAYS"/>
    <Button text="Fermer" styleClass="action-secondaire" onAction="#fermer"/>
  </HBox>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  M-Passage - écran pivot d'un passage (détail) : fil d'Ariane (affichage), bandeau d'identité,
  stepper de statut workflow et onglets (Vue d'ensemble, Diagnostic, Validation Tadarida). Le bouton
  « Vérifier » ouvre M-Qualification et « Diagnostic » ouvre M-Diagnostic (contrats socle). La
  validation Tadarida arrive dans la tranche suivante. Pur câblage : tout est lié au
  PassageViewModel par PassageController.

  TODO (M-Passage) : écran pivot à construire. Le placeholder ci-dessous n'affiche qu'un titre ;
  remplacez-le par la vraie mise en page (bandeau d'identité, stepper de statut, stats, actions vers
  les autres écrans) reliée au PassageController par des fx:id et des onAction. Réf : sites/view/SiteDetail.fxml.
-->
<!-- @@solution@@ -->
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:id="racine"
            fx:controller="fr.univ_amu.iut.passage.view.PassageController"
            stylesheets="@passage.css"
            styleClass="ecran-passage">

  <top>
    <VBox spacing="12.0" styleClass="entete">
      <Label fx:id="lblFilAriane" styleClass="fil-ariane"/>
      <HBox alignment="CENTER_LEFT" spacing="12.0">
        <Label fx:id="lblTitre" styleClass="titre-page" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        <Button fx:id="boutonRattachement" text="✏ Modifier rattachement"
                styleClass="action-secondaire" onAction="#modifierRattachement"/>
        <Button fx:id="boutonSupprimer" text="🗑 Supprimer" styleClass="bouton-danger"
                onAction="#supprimer"/>
      </HBox>

      <!-- Bandeau d'identité du passage -->
      <HBox spacing="28.0" styleClass="bandeau">
        <VBox spacing="2.0">
          <Label text="DATE / PLAGE" styleClass="bandeau-label"/>
          <Label fx:id="lblPlageHoraire" styleClass="bandeau-valeur"/>
        </VBox>
        <VBox spacing="2.0">
          <Label text="ENREGISTREUR" styleClass="bandeau-label"/>
          <Label fx:id="lblEnregistreur" styleClass="bandeau-valeur"/>
        </VBox>
        <VBox spacing="2.0">
          <Label text="STATUT" styleClass="bandeau-label"/>
          <Label fx:id="lblStatut" styleClass="bandeau-valeur"/>
        </VBox>
        <VBox spacing="2.0">
          <Label text="VERDICT" styleClass="bandeau-label"/>
          <Label fx:id="lblVerdict" styleClass="bandeau-valeur"/>
        </VBox>
      </HBox>

      <!-- Stepper de statut workflow -->
      <VBox spacing="4.0">
        <Label text="Statut du workflow" styleClass="section-sous"/>
        <HBox fx:id="stepper" spacing="8.0" styleClass="stepper"/>
      </VBox>

      <Label fx:id="lblMessage" styleClass="message-erreur" wrapText="true"/>
    </VBox>
  </top>

  <center>
    <TabPane styleClass="onglets" tabClosingPolicy="UNAVAILABLE">
      <tabs>
        <Tab text="Vue d'ensemble">
          <VBox spacing="16.0" styleClass="onglet-contenu">

            <!-- Statistiques de la nuit -->
            <HBox spacing="14.0" styleClass="stats">
              <VBox spacing="2.0" styleClass="stat-carte">
                <Label text="VOLUME BRUTS" styleClass="stat-label"/>
                <Label fx:id="lblVolBruts" styleClass="stat-valeur"/>
              </VBox>
              <VBox spacing="2.0" styleClass="stat-carte">
                <Label text="VOLUME TRANSFORMÉ" styleClass="stat-label"/>
                <Label fx:id="lblVolTransformes" styleClass="stat-valeur"/>
              </VBox>
              <VBox spacing="2.0" styleClass="stat-carte">
                <Label text="DURÉE AUDIBLE" styleClass="stat-label"/>
                <Label fx:id="lblDureeAudible" styleClass="stat-valeur"/>
              </VBox>
              <VBox spacing="2.0" styleClass="stat-carte">
                <Label text="SÉQUENCES" styleClass="stat-label"/>
                <Label fx:id="lblNbSequences" styleClass="stat-valeur"/>
              </VBox>
            </HBox>

            <!-- Actions rapides -->
            <Label text="Actions rapides" styleClass="section-sous"/>
            <HBox spacing="14.0">
              <Button fx:id="boutonVerifier" text="🎧 Vérifier l'enregistrement"
                      styleClass="action-primaire" onAction="#verifier"/>
              <Button fx:id="boutonDiagnostic" text="🔧 Diagnostic matériel"
                      styleClass="action-secondaire" onAction="#diagnostiquer"/>
              <Button fx:id="boutonDepot" text="📦 Préparer le dépôt"
                      styleClass="action-secondaire" onAction="#preparerDepot"/>
              <Button fx:id="boutonValidation" text="✅ Validation Tadarida 🔒"
                      styleClass="action-secondaire" onAction="#validerTadarida"/>
              <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <Label fx:id="lblIndiceAction" styleClass="section-sous" wrapText="true"/>
          </VBox>
        </Tab>
        <Tab text="Diagnostic matériel">
          <VBox alignment="CENTER" spacing="14.0" styleClass="onglet-contenu">
            <Label text="Le diagnostic matériel (T°/hygrométrie, anomalies, journal) s'affiche en plein écran."
                   styleClass="section-sous" wrapText="true"/>
            <Button fx:id="boutonOuvrirDiagnostic" text="🔧 Ouvrir le diagnostic matériel"
                    styleClass="action-primaire" onAction="#diagnostiquer"/>
          </VBox>
        </Tab>
        <Tab text="Validation Tadarida">
          <VBox alignment="CENTER" spacing="14.0" styleClass="onglet-contenu">
            <Label fx:id="lblValidation" styleClass="section-sous" wrapText="true"/>
            <Button fx:id="boutonOuvrirValidation" text="✅ Ouvrir la validation Tadarida"
                    styleClass="action-primaire" onAction="#validerTadarida"/>
          </VBox>
        </Tab>
      </tabs>
    </TabPane>
  </center>
</BorderPane>
<!-- @@end-solution@@ -->

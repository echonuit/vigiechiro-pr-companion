<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
  M-Passage - écran pivot d'un passage (détail), en « hub à plat » : bandeau d'identité, stepper de
  statut workflow, résumé de la nuit (stats) et un jeu de cartes d'actions « avancer » (Vérifier,
  Diagnostic, Préparer le dépôt, Sons & validation). Le retour et le fil d'Ariane sont portés par le
  chrome (commun) : pas de fil interne ni d'onglets-lanceurs ici. Les cartes ouvrent M-Qualification,
  M-Diagnostic, M-Lot et M-Vision-Tadarida via les contrats socle (Ouvrir*). Pur câblage : tout est
  lié au PassageViewModel par PassageController.
-->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="fr.univ_amu.iut.passage.view.PassageController"
           stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css, @passage.css"
           fx:id="hoteOccupation">
  <!-- Hôte d'occupation (#1213) : voile « … en cours » pendant le chargement de la projection. -->
  <BorderPane fx:id="racine" styleClass="ecran-passage">

  <top>
    <VBox spacing="12.0" styleClass="entete">
      <!-- En-tête réduit à ses actions (#693) : le contexte (carré / point / N°) est déporté en zone
           gauche de la barre de statut ; le bandeau d'identité ci-dessous reste. -->
      <HBox styleClass="entete-actions" alignment="CENTER_RIGHT">
        <Button fx:id="boutonVoirCarte" text="Voir sur la carte"
                styleClass="bouton-secondaire" onAction="#voirSurCarte">
          <graphic>
            <FontIcon iconLiteral="fas-map"/>
          </graphic>
        </Button>
        <!-- Enveloppe (#789) : le tooltip d'explication doit survivre à la désactivation du bouton. -->
        <StackPane fx:id="enveloppeOuvrirPortail">
          <Button fx:id="boutonOuvrirPortail" text="Voir la participation"
                  styleClass="bouton-secondaire" onAction="#ouvrirSurVigieChiro">
            <graphic>
              <FontIcon iconLiteral="fas-globe"/>
            </graphic>
          </Button>
        </StackPane>
        <!-- Enveloppe (#789) : le tooltip d'explication doit survivre à la désactivation du bouton
             (un passage déposé n'est plus renommable). -->
        <StackPane fx:id="enveloppeRattachement">
          <Button fx:id="boutonRattachement" text="Modifier le passage"
                  styleClass="bouton-secondaire" onAction="#modifierRattachement">
            <graphic>
              <FontIcon iconLiteral="fas-pen"/>
            </graphic>
          </Button>
        </StackPane>
        <Button fx:id="boutonAnnulerDepot" text="Annuler le dépôt"
                styleClass="bouton-secondaire" onAction="#annulerDepot">
          <graphic>
            <FontIcon iconLiteral="fas-undo"/>
          </graphic>
        </Button>
        <Button fx:id="boutonPurger" text="Purger les originaux"
                styleClass="bouton-secondaire" onAction="#purgerOriginaux"
                visible="false" managed="false">
          <graphic>
            <FontIcon iconLiteral="fas-broom"/>
          </graphic>
        </Button>
        <!-- Enveloppe (#789) : le tooltip explique pourquoi l'archivage est bloqué (passage non déposé,
             ou déjà archivé) et survit à la désactivation du bouton (#1300). -->
        <StackPane fx:id="enveloppeArchiver">
          <Button fx:id="boutonArchiver" text="Archiver ce passage"
                  styleClass="bouton-secondaire" onAction="#archiver">
            <graphic>
              <FontIcon iconLiteral="fas-box"/>
            </graphic>
          </Button>
        </StackPane>
        <!-- Enveloppe (#789) : le tooltip explique pourquoi la réactivation est bloquée (rien à
             réactiver : audio déjà là, ou aucune séquence importée) et survit à la désactivation (#1302). -->
        <StackPane fx:id="enveloppeReactiver">
          <Button fx:id="boutonReactiver" text="Réactiver ce passage"
                  styleClass="bouton-secondaire" onAction="#reactiver">
            <graphic>
              <FontIcon iconLiteral="fas-recycle"/>
            </graphic>
          </Button>
        </StackPane>
        <!-- Enveloppe : un Tooltip ne s'affiche pas sur un Button désactivé ; on l'installe sur ce
             StackPane (qui, lui, reçoit le survol) pour expliquer pourquoi la suppression est bloquée
             sur un passage déposé (#789). -->
        <StackPane fx:id="enveloppeSupprimer">
          <Button fx:id="boutonSupprimer" text="Supprimer" styleClass="bouton-danger"
                  onAction="#supprimer">
            <graphic>
              <FontIcon iconLiteral="fas-trash"/>
            </graphic>
          </Button>
        </StackPane>
      </HBox>

      <!-- Bandeau d'identité du passage (composant partagé bandeau-infos, #694) -->
      <HBox spacing="0.0" styleClass="bandeau-infos">
        <VBox spacing="2.0" styleClass="bandeau-cellule">
          <Label text="DATE / PLAGE" styleClass="bandeau-label"/>
          <Label fx:id="lblPlageHoraire" styleClass="bandeau-valeur"/>
        </VBox>
        <VBox spacing="2.0" styleClass="bandeau-cellule">
          <Label text="ENREGISTREUR" styleClass="bandeau-label"/>
          <Label fx:id="lblEnregistreur" styleClass="bandeau-valeur"/>
        </VBox>
        <VBox spacing="2.0" styleClass="bandeau-cellule">
          <Label text="STATUT" styleClass="bandeau-label"/>
          <Label fx:id="lblStatut" styleClass="bandeau-valeur"/>
        </VBox>
        <VBox spacing="2.0" styleClass="bandeau-cellule">
          <Label text="VERDICT" styleClass="bandeau-label"/>
          <Label fx:id="lblVerdict" styleClass="bandeau-valeur"/>
        </VBox>
      </HBox>

      <!-- Stepper de statut workflow -->
      <VBox spacing="4.0">
        <Label text="Statut du workflow" styleClass="section-titre"/>
        <HBox fx:id="stepper" spacing="8.0" styleClass="stepper"/>
      </VBox>

      <!-- Bandeau de retour partagé (ADR 0023) : style dans commun/view/design.css, câblage dans
           commun/view/BandeauRetour. Remplace le libellé d'erreur ad hoc, qui n'avait ni sévérité ni
           fermeture. Distinct de lblStatut ci-dessus, qui porte l'état permanent de la nuit. -->
      <HBox fx:id="bandeauRetour" styleClass="bandeau-retour" alignment="CENTER_LEFT" spacing="10.0">
        <Label fx:id="lblRetour" wrapText="true" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button fx:id="btnFermerRetour" styleClass="fermer-retour" accessibleText="Fermer le message">
          <graphic>
            <FontIcon iconLiteral="fas-times"/>
          </graphic>
        </Button>
      </HBox>
    </VBox>
  </top>

  <center>
    <VBox spacing="16.0" styleClass="hub-contenu">

      <!-- Résumé de la nuit -->
      <Label text="Résumé de la nuit" styleClass="section-titre"/>
      <HBox spacing="14.0" styleClass="stats">
        <VBox spacing="2.0" styleClass="carte-stat" maxWidth="Infinity" HBox.hgrow="ALWAYS">
          <Label text="VOLUME BRUTS" styleClass="carte-stat-libelle"/>
          <Label fx:id="lblVolBruts" styleClass="carte-stat-valeur"/>
        </VBox>
        <VBox spacing="2.0" styleClass="carte-stat" maxWidth="Infinity" HBox.hgrow="ALWAYS">
          <Label text="VOLUME TRANSFORMÉ" styleClass="carte-stat-libelle"/>
          <Label fx:id="lblVolTransformes" styleClass="carte-stat-valeur"/>
        </VBox>
        <VBox spacing="2.0" styleClass="carte-stat" maxWidth="Infinity" HBox.hgrow="ALWAYS">
          <Label text="DURÉE ENREGISTRÉE" styleClass="carte-stat-libelle"/>
          <Label fx:id="lblDureeEnregistree" styleClass="carte-stat-valeur"/>
        </VBox>
        <VBox spacing="2.0" styleClass="carte-stat" maxWidth="Infinity" HBox.hgrow="ALWAYS">
          <Label text="SÉQUENCES" styleClass="carte-stat-libelle"/>
          <Label fx:id="lblNbSequences" styleClass="carte-stat-valeur"/>
        </VBox>
      </HBox>

      <!-- Actions : avancer dans le workflow (le retour et le fil d'Ariane sont portés par le chrome) -->
      <Label text="Actions" styleClass="section-titre"/>
      <HBox spacing="16.0" fillHeight="true" styleClass="cartes-actions">
        <Button fx:id="boutonVerifier" styleClass="carte-action"
                onAction="#verifier" contentDisplay="GRAPHIC_ONLY"
                accessibleText="Vérifier l'enregistrement : sound check par échantillonnage"
                maxWidth="Infinity" maxHeight="Infinity" HBox.hgrow="ALWAYS">
          <graphic>
            <VBox alignment="CENTER" spacing="6.0" styleClass="carte-action-contenu">
              <FontIcon iconLiteral="fas-headphones" styleClass="carte-action-icone"/>
              <Label text="Vérifier l'enregistrement" styleClass="carte-action-titre" wrapText="true"/>
              <Label text="Sound check par échantillonnage" styleClass="carte-action-sous" wrapText="true"/>
            </VBox>
          </graphic>
        </Button>
        <Button fx:id="boutonDiagnostic" styleClass="carte-action"
                onAction="#diagnostiquer" contentDisplay="GRAPHIC_ONLY"
                accessibleText="Diagnostic matériel : température, hygrométrie, anomalies, journal"
                maxWidth="Infinity" maxHeight="Infinity" HBox.hgrow="ALWAYS">
          <graphic>
            <VBox alignment="CENTER" spacing="6.0" styleClass="carte-action-contenu">
              <FontIcon iconLiteral="fas-tools" styleClass="carte-action-icone"/>
              <Label text="Diagnostic matériel" styleClass="carte-action-titre" wrapText="true"/>
              <Label text="T°/hygrométrie, anomalies, journal" styleClass="carte-action-sous" wrapText="true"/>
            </VBox>
          </graphic>
        </Button>
        <Button fx:id="boutonDepot" styleClass="carte-action"
                onAction="#preparerDepot" contentDisplay="GRAPHIC_ONLY"
                accessibleText="Préparer le dépôt : constituer le jeu Tadarida"
                maxWidth="Infinity" maxHeight="Infinity" HBox.hgrow="ALWAYS">
          <graphic>
            <VBox alignment="CENTER" spacing="6.0" styleClass="carte-action-contenu">
              <FontIcon iconLiteral="fas-box-open" styleClass="carte-action-icone"/>
              <Label text="Préparer le dépôt" styleClass="carte-action-titre" wrapText="true"/>
              <Label text="Constituer le jeu Tadarida" styleClass="carte-action-sous" wrapText="true"/>
            </VBox>
          </graphic>
        </Button>
        <Button fx:id="boutonValidation" styleClass="carte-action"
                onAction="#validerTadarida" contentDisplay="GRAPHIC_ONLY"
                accessibleText="Sons et validation : écouter et valider les sons du passage"
                maxWidth="Infinity" maxHeight="Infinity" HBox.hgrow="ALWAYS">
          <graphic>
            <VBox alignment="CENTER" spacing="6.0" styleClass="carte-action-contenu">
              <FontIcon iconLiteral="fas-check-circle" styleClass="carte-action-icone"/>
              <Label text="Sons &amp; validation" styleClass="carte-action-titre" wrapText="true"/>
              <Label text="Écouter et valider les sons du passage" styleClass="carte-action-sous" wrapText="true"/>
            </VBox>
          </graphic>
        </Button>
      </HBox>
      <Label fx:id="lblIndiceAction" styleClass="section-sous" wrapText="true"/>
    </VBox>
  </center>
  </BorderPane>
</StackPane>


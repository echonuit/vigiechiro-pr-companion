<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
  M-Lot - préparation et dépôt d'un passage sur Vigie-Chiro (parcours P4, épopée E4).
  Atteint depuis M-Passage via le contrat socle OuvrirLot. Pur câblage : statut, récapitulatif,
  stepper du dépôt et les actions (préparer / générer les archives / marquer déposé) sont liés au
  LotViewModel par le controller.

  Refonte #251 : un seul flux ORDONNÉ rendu lisible par un stepper (cohérent avec M-Passage), au lieu
  d'un panneau « Archives » flottant après « Marquer déposé ». L'artefact réellement téléversé = les
  archives ZIP (≤ 700 Mo) écrites dans depot/ ; le dépôt lui-même reste manuel (aucun accès réseau).
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.univ_amu.iut.lot.view.LotController"
      stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css, @lot.css"
      styleClass="ecran-lot"
      spacing="14.0">

  <!--
    En-tête retiré (#693) : le titre « Préparer le dépôt » est redondant avec le fil d'Ariane, et le
    statut du workflow est déporté en barre de statut par le controller (ResumeStatut).
  -->

  <!-- Stepper du dépôt (#251) : ① Préparer · ② Générer les archives · ③ Téléverser · ④ Marquer déposé. -->
  <HBox fx:id="stepper" styleClass="stepper" spacing="8.0"/>

  <!-- État du lot en prose (version lisible du stepper) : permanent, non fermable. Distinct du bandeau
       de retour ci-dessous, avec lequel il partageait un canal unique avant #1890. -->
  <Label fx:id="lblEtatLot" styleClass="message-lot" wrapText="true"/>

  <!-- Bandeau de retour partagé (ADR 0023) : un seul pour les deux ViewModels de l'écran, en tête de
       flux. Style dans commun/view/design.css, câblage dans commun/view/BandeauRetour. -->
  <HBox fx:id="bandeauRetour" styleClass="bandeau-retour" alignment="CENTER_LEFT" spacing="10.0">
    <Label fx:id="lblRetour" wrapText="true" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    <Button fx:id="btnFermerRetour" styleClass="fermer-retour" accessibleText="Fermer le message">
      <graphic>
        <FontIcon iconLiteral="fas-times"/>
      </graphic>
    </Button>
  </HBox>

  <Separator/>

  <!-- Étape 1 - Vérifier et préparer le dépôt -->
  <VBox spacing="4.0" styleClass="carte-section">
    <Label text="1. Vérifier et préparer le dépôt" styleClass="section-titre"/>
    <Label text="Avant le dépôt, l'application vérifie que la nuit est complète et conforme."
           styleClass="section-sous" wrapText="true"/>
    <Label text="Elle verrouille ensuite la liste des séquences qui partiront sur Vigie-Chiro. Vos fichiers d'origine ne sont pas modifiés."
           styleClass="section-sous" wrapText="true"/>
    <Label text="Contrôles de cohérence :" styleClass="controle-intro"/>
    <!-- Checklist vivante (#254) : une ligne ✓ / ✗ / ⚠ par contrôle, construite par le controller. -->
    <VBox fx:id="checklist" spacing="3.0"/>
    <!-- Enveloppe : un Button désactivé n'affiche pas de Tooltip, on le pose sur ce StackPane (#789). -->
    <StackPane fx:id="enveloppePreparer" alignment="CENTER_LEFT">
      <Button fx:id="btnPreparer" text="Vérifier et préparer le dépôt"
              styleClass="bouton-primaire" onAction="#preparer">
        <graphic>
          <FontIcon iconLiteral="fas-box"/>
        </graphic>
      </Button>
    </StackPane>
  </VBox>

  <!-- Étape 2 - Générer les archives ZIP (le payload réellement déposé) -->
  <VBox spacing="4.0" styleClass="carte-section">
    <HBox alignment="CENTER_LEFT" spacing="8.0">
      <Label text="2. Générer les archives de dépôt" styleClass="section-titre" HBox.hgrow="ALWAYS"/>
      <MenuButton fx:id="menuOutils" styleClass="menu-actions" accessibleText="Outils : colonnes">
        <graphic>
          <FontIcon iconLiteral="fas-bars"/>
        </graphic>
      </MenuButton>
    </HBox>
    <!-- L'icone se pose ICI et non dans le viewmodel : un viewmodel ne connait que javafx.beans,
         jamais javafx.scene (regle ArchUnit viewmodel_sans_javafx_ui). Il fournit le texte, la vue
         le decore (#1564). -->
    <Label fx:id="lblTitreArchives" styleClass="section-sous">
      <graphic>
        <FontIcon iconLiteral="fas-file-archive"/>
      </graphic>
    </Label>
    <Label text="Découpe les séquences en archives ZIP « préfixe-N.zip » prêtes à téléverser, écrites dans le sous-dossier « depot/ » de la session."
           styleClass="section-sous" wrapText="true"/>
    <HBox spacing="8.0" alignment="CENTER_LEFT">
      <Button fx:id="btnGenererArchives" text="Générer les archives de dépôt"
              styleClass="bouton-secondaire" onAction="#genererArchives">
        <graphic>
          <FontIcon iconLiteral="fas-file-archive"/>
        </graphic>
      </Button>
      <!-- Progression déterminée (#769) : barre + estimation de durée, visibles pendant la génération. -->
      <ProgressBar fx:id="barreGeneration" prefWidth="220.0" maxWidth="Infinity" progress="0.0"
                   visible="false" managed="false" HBox.hgrow="ALWAYS"/>
    </HBox>
    <Label fx:id="lblProgressionGeneration" styleClass="section-sous"
           visible="false" managed="false"/>
    <!-- Alerte espace disque (#…) : bandeau rouge pleine largeur juste sous le bouton, affiché quand la
         génération est désactivée faute de place (proactif, sans attendre le clic). -->
    <Label fx:id="lblEspaceInsuffisant" styleClass="bandeau-statut, badge-danger" wrapText="true"
           visible="false" managed="false"/>
    <!-- Table de suivi (#820) : une ligne + une barre par archive ZIP (en attente / en cours / terminée).
         Colonnes et cellule d'état construites par le controller (TableSuiviArchives). -->
    <TableView fx:id="tableArchives" minHeight="120.0" prefHeight="160.0"/>
  </VBox>

  <!-- Étape 3 - Téléverser sur Vigie-Chiro (automatisé #142, avec repli manuel par le dossier depot/) -->
  <VBox spacing="4.0" styleClass="carte-section">
    <Label text="3. Téléverser sur Vigie-Chiro" styleClass="section-titre"/>
    <Label text="Téléversez la nuit directement sur Vigie-Chiro (les séquences transformées, au format attendu par la plateforme). En cas de besoin, un dépôt manuel des archives ZIP reste possible depuis le dossier :"
           styleClass="section-sous" wrapText="true"/>
    <Label fx:id="lblCheminDepot" styleClass="chemin" wrapText="true"/>
    <!-- Téléversement automatisé (#142) et repli manuel côte à côte : quand le téléversement direct est
         indisponible (application non connectée), l'enveloppe de btnTeleverser est démanagée et « Ouvrir le
         dossier » reste seul à gauche. Le message d'avancement/bilan du téléversement suit en dessous.
         Enveloppes StackPane (#789) : un Button désactivé n'affiche pas de Tooltip, on l'expose sur son
         enveloppe pour expliquer le grisage au survol. -->
    <HBox spacing="8.0" alignment="CENTER_LEFT">
      <StackPane fx:id="enveloppeTeleverser" alignment="CENTER_LEFT">
        <Button fx:id="btnTeleverser" text="Téléverser sur Vigie-Chiro"
                styleClass="bouton-primaire" onAction="#televerserVigieChiro">
          <graphic>
            <FontIcon fx:id="iconeTeleverser" iconLiteral="fas-cloud"/>
          </graphic>
        </Button>
      </StackPane>
      <StackPane fx:id="enveloppeOuvrirDepot" alignment="CENTER_LEFT">
        <Button fx:id="btnOuvrirDepot" text="Ouvrir le dossier (dépôt manuel)"
                styleClass="bouton-secondaire" onAction="#ouvrirDossierDepot">
          <graphic>
            <FontIcon iconLiteral="fas-folder-open"/>
          </graphic>
        </Button>
      </StackPane>
      <!-- Annulation coopérative du dépôt (#1044) : visible seulement pendant un téléversement. Le
           fichier en cours se termine d'abord (jamais d'arrêt au milieu d'un fichier) ; « Reprendre le
           dépôt » ne renverra ensuite que les manquants. -->
      <Button fx:id="btnAnnulerDepot" styleClass="bouton-secondaire" onAction="#annulerDepotVigieChiro"
              visible="false" managed="false">
        <tooltip>
          <Tooltip text="Termine le fichier en cours puis s'arrête. Le passage reste « Dépôt en cours » : reprendre le dépôt ne renverra que les fichiers manquants."/>
        </tooltip>
      </Button>
      <!-- Réinitialiser le dépôt (#984) : efface le suivi local pour forcer un nouveau téléversement.
           Visible dès qu'un plan de dépôt existe (câblé par le contrôleur). -->
      <Button fx:id="btnReinitialiserDepot" text="Réinitialiser le dépôt"
              styleClass="bouton-secondaire" onAction="#reinitialiserDepot" visible="false" managed="false">
        <graphic>
          <FontIcon iconLiteral="fas-sync-alt"/>
        </graphic>
        <tooltip>
          <Tooltip text="Efface le suivi local de dépôt pour permettre un nouveau téléversement. Les archives ZIP sur disque et la participation Vigie-Chiro sont conservées."/>
        </tooltip>
      </Button>
    </HBox>
    <!-- Table de dépôt (#983) : une ligne par unité téléversée (état persisté depot_unite #981),
         réhydratée à l'ouverture et vivante pendant un dépôt. Masquée tant qu'aucun dépôt automatique
         n'a été entamé. -->
    <TableView fx:id="tableDepot" minHeight="150.0" prefHeight="170.0" visible="false" managed="false"/>
  </VBox>

  <!-- Étape 4 - Marquer déposé -->
  <VBox spacing="4.0" styleClass="carte-section">
    <Label text="4. Marquer le passage déposé" styleClass="section-titre"/>
    <Label text="Une fois le téléversement effectué sur Vigie-Chiro, enregistrez le dépôt."
           styleClass="section-sous" wrapText="true"/>
    <StackPane fx:id="enveloppeDeposer" alignment="CENTER_LEFT">
      <Button fx:id="btnDeposer" text="Marquer déposé"
              styleClass="bouton-secondaire" onAction="#deposer">
        <graphic>
          <FontIcon fx:id="iconeDeposer" iconLiteral="fas-check"/>
        </graphic>
      </Button>
    </StackPane>
  </VBox>

  <!-- Traitement serveur (#1263) : « Déposé » n'est pas la fin. Vigie-Chiro analyse ensuite la nuit avec
       Tadarida, et les observations ne sont récupérables qu'une fois cette analyse terminée. La zone
       n'apparaît qu'une fois la nuit déposée par l'application (participation liée) : avant, il n'y a rien
       à suivre. Aucun sondage : l'état est relu à l'ouverture (cache), sur demande, ou après un lancement. -->
  <VBox fx:id="zoneTraitement" spacing="4.0" styleClass="carte-section" visible="false" managed="false">
    <Label text="Traitement Vigie-Chiro" styleClass="section-titre"/>
    <Label fx:id="lblEtatTraitement" styleClass="section-sous" wrapText="true"/>
    <Label fx:id="lblFraicheurTraitement" styleClass="section-sous" wrapText="true"/>
    <Label fx:id="lblAlerteTraitement" styleClass="message-lot" wrapText="true"/>
    <Button fx:id="btnActualiserTraitement" text="Actualiser" styleClass="bouton-secondaire">
      <graphic>
        <FontIcon iconLiteral="fas-sync-alt"/>
      </graphic>
    </Button>
  </VBox>

  <!-- Nettoyage optionnel - libérer l'espace disque (#2028) : la carte ne s'affiche que quand elle a
       quelque chose à proposer (passage déposé ET archives ZIP encore sur disque, cf.
       peutSupprimerArchives). Un téléversement par l'application efface les siennes lui-même (#1995) ;
       ces archives-ci viennent d'une génération pour dépôt manuel. Régénérables à l'identique. -->
  <VBox fx:id="zoneLibererEspace" spacing="4.0" styleClass="carte-section">
    <Label text="Libérer l'espace disque" styleClass="section-titre"/>
    <Label text="Des archives ZIP occupent le dossier depot/. Vous pouvez les supprimer pour libérer de l'espace : elles se régénèrent à l'identique via « Générer les archives ». Un téléversement par l'application efface les siennes au fur et à mesure ; celles-ci subsistent (par exemple après une génération pour un dépôt manuel)."
           styleClass="section-sous" wrapText="true"/>
    <Button fx:id="btnSupprimerArchives" text="Supprimer les archives de dépôt"
            styleClass="bouton-secondaire" onAction="#supprimerArchives">
      <graphic>
        <FontIcon iconLiteral="fas-trash"/>
      </graphic>
    </Button>
  </VBox>

</VBox>

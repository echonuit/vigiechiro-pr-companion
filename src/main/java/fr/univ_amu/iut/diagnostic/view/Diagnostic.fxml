<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
  M-Diagnostic - état matériel d'une nuit (parcours P6). Atteint depuis l'onglet « Diagnostic » de
  M-Passage via le contrat socle OuvrirDiagnostic. Pur câblage : tout est lié au DiagnosticViewModel
  par DiagnosticController (graphe T°/hygrométrie, anomalies et évènements du journal).
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.univ_amu.iut.diagnostic.view.DiagnosticController"
      stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css, @diagnostic.css"
      styleClass="ecran-diagnostic"
      spacing="14.0">

  <!--
    En-tête retiré (#693) : le titre « Diagnostic matériel » est redondant avec le fil d'Ariane, et
    l'enregistreur diagnostiqué est déporté en barre de statut par le controller (ResumeStatut).
  -->

  <Label fx:id="lblReleveAbsent" styleClass="alerte-r20" wrapText="true"
         text="⚠ Relevé climatique absent : la température et l'hygrométrie ne sont pas disponibles pour cette nuit."/>

  <Label fx:id="lblResumeClimat" styleClass="section-sous"/>
  <!-- Température en début de nuit (#106) : donnée optionnelle saisie dans M-Passage. -->
  <Label fx:id="lblTemperature" styleClass="section-sous"/>
  <!-- Axe X temporel (#1498) : NumberAxis en minutes depuis la 1re mesure, étiqueté HH:mm par le
       controller (6 à 8 repères). Remplace un CategoryAxis qui affichait un libellé par mesure. -->
  <LineChart fx:id="grapheClimat" VBox.vgrow="ALWAYS" minHeight="260.0" legendVisible="true" animated="false">
    <xAxis>
      <NumberAxis label="Heure"/>
    </xAxis>
    <yAxis>
      <NumberAxis label="T° (°C) / Humidité (%)"/>
    </yAxis>
  </LineChart>

  <HBox spacing="14.0" VBox.vgrow="ALWAYS">
    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
      <Label text="⚠ Anomalies" styleClass="section-titre"/>
      <ListView fx:id="listeAnomalies" VBox.vgrow="ALWAYS">
        <placeholder>
          <Label text="Aucune anomalie détectée." wrapText="true"/>
        </placeholder>
      </ListView>
    </VBox>
    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
      <Label text="📋 Évènements du journal" styleClass="section-titre"/>
      <ListView fx:id="listeEvenements" VBox.vgrow="ALWAYS">
        <placeholder>
          <Label text="Aucun évènement dans le journal du capteur." wrapText="true"/>
        </placeholder>
      </ListView>
    </VBox>
  </HBox>

  <!-- Cohérence horaires (#548) : fenêtre nocturne réelle au point + repère « hors nuit ». -->
  <Label fx:id="lblFenetreNuit" styleClass="section-sous"/>
  <Label fx:id="lblAlerteHorsNuit" styleClass="alerte-r20" wrapText="true"/>

  <!--
    Disponibilité GPS du point d'écoute (#1497) : ligne d'état permanente, affichée dès qu'un
    diagnostic est chargé et indépendante de la cohérence horaires (le repère ne disparaît plus
    quand la fenêtre nocturne est calculable). Icône et couleur posées par le controller via
    icone-gps + les classes gps-disponible / gps-absent. Provenance : coordonnées du point d'écoute
    (feature sites), pas du capteur.
  -->
  <HBox fx:id="ligneGps" styleClass="ligne-gps" alignment="CENTER_LEFT" spacing="8.0">
    <FontIcon fx:id="iconeGps" styleClass="icone-gps"/>
    <Label fx:id="lblGps" wrapText="true"/>
  </HBox>
  <Label fx:id="lblMessage" styleClass="message-erreur" wrapText="true"/>
</VBox>

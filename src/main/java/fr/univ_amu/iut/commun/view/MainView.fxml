<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
  Chrome principal de VigieChiro PR Companion (socle IHM).
  - top    : barre de navigation (titre application + fil d'Ariane)
  - center : zone d'accueil (placeholder ; échangée par les features via le Navigateur)
  - bottom : pied de page
  Le centre est lié par MainController au Navigateur : pour le changer, passer par afficher(...).
-->
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:id="racine"
            fx:controller="fr.univ_amu.iut.commun.view.MainController"
            stylesheets="@base.css"
            styleClass="fenetre-principale"
            prefWidth="960.0" prefHeight="640.0">

  <top>
    <!-- Barre de navigation : titre app, bouton ← Retour (historique) et fil d'Ariane (emplacement)
         peuplé par MainController. Retour + fil sont dans le chrome → présents sur TOUS les écrans. -->
    <HBox styleClass="barre-navigation" alignment="CENTER_LEFT" spacing="14.0">
      <Label fx:id="titreApplication" styleClass="titre-application"
             text="VigieChiro PR Companion"/>
      <Button fx:id="boutonRetour" styleClass="bouton-retour" text="← Retour" onAction="#revenir"/>
      <HBox fx:id="filAriane" styleClass="fil-ariane" alignment="CENTER_LEFT" spacing="4.0"
            HBox.hgrow="ALWAYS"/>
    </HBox>
  </top>

  <center>
    <VBox fx:id="zoneAccueil" styleClass="zone-accueil" spacing="0.0">
      <!-- Hero nocturne : bandeau en dégradé bleu nuit (identité « une nuit de capture »), avec
           titre, invite et tableau de bord de compteurs. Le filigrane décoratif déborde
           volontairement ; MainController clippe le hero à ses bornes. -->
      <StackPane fx:id="hero" styleClass="hero-nocturne">
        <FontIcon iconLiteral="fas-moon" styleClass="hero-filigrane" StackPane.alignment="TOP_RIGHT"/>
        <VBox styleClass="hero-contenu" alignment="CENTER" spacing="14.0">
          <Label styleClass="titre-accueil" text="Bienvenue dans VigieChiro PR Companion"/>
          <Label styleClass="sous-titre-accueil" wrapText="true" textAlignment="CENTER"
                 text="Sélectionnez une activité pour traiter une nuit d'enregistrement (Passive Recorder)."/>
          <!-- Bandeau de compteurs (tableau de bord) peuplé par MainController à partir des
               IndicateurAccueil des features. Masqué tant qu'aucune donnée n'existe. -->
          <FlowPane fx:id="bandeauIndicateurs" styleClass="bandeau-indicateurs"
                    alignment="CENTER" hgap="12.0" vgap="12.0"/>
        </VBox>
      </StackPane>
      <!-- Zone des cartes d'activités, peuplées par MainController à partir des ActiviteAccueil
           des features. -->
      <VBox styleClass="zone-cartes" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="cartesActivites" styleClass="cartes-activites"
                  alignment="CENTER" hgap="16.0" vgap="16.0"/>
      </VBox>
    </VBox>
  </center>

  <bottom>
    <Label fx:id="pied" styleClass="pied-page" maxWidth="Infinity"
           text="SAÉ 2.01 · IUT d'Aix-Marseille"/>
  </bottom>
</BorderPane>

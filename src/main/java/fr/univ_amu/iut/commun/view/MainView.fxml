<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckMenuItem?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
  Chrome principal de VigieChiro PR Companion (socle IHM).
  - top    : barre de navigation (titre application + fil d'Ariane + recherche globale)
  - center : zone d'accueil (placeholder ; échangée par les features via le Navigateur)
  - bottom : pied de page
  Le centre est lié par MainController au Navigateur : pour le changer, passer par afficher(...).
  La racine est un StackPane : le chrome (BorderPane) + un panneau de résultats de recherche superposé
  (liste déroulante #144), masqué tant qu'il n'y a pas de résultats.
-->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="fr.univ_amu.iut.commun.view.MainController"
           stylesheets="@palette.css, @base.css"
           styleClass="fenetre-principale"
           prefWidth="960.0" prefHeight="640.0">

  <BorderPane fx:id="racine">

    <top>
      <!-- Barre de navigation : titre app, bouton ← Retour (historique), fil d'Ariane (emplacement)
           peuplé par MainController, et le champ de recherche globale (#144) aligné à droite. -->
      <HBox styleClass="barre-navigation" alignment="CENTER_LEFT" spacing="14.0">
        <Label fx:id="titreApplication" styleClass="titre-application"
               text="VigieChiro PR Companion"/>
        <!-- Enveloppe : un Button désactivé n'affiche pas de Tooltip ; on le pose sur ce StackPane (qui
             reçoit le survol) pour expliquer le grisage du retour pendant un import (#789). L'enveloppe
             suit la visibilité du bouton (présent hors accueil). -->
        <StackPane fx:id="enveloppeRetour">
          <Button fx:id="boutonRetour" styleClass="bouton-retour" text="← Retour" onAction="#revenir"/>
        </StackPane>
        <HBox fx:id="filAriane" styleClass="fil-ariane" alignment="CENTER_LEFT" spacing="4.0"
              HBox.hgrow="ALWAYS"/>
        <TextField fx:id="champRecherche" styleClass="champ-recherche" promptText="🔍 Rechercher (Ctrl+F)"
                   prefWidth="240.0"/>
        <MenuButton fx:id="menuOutils" text="☰" styleClass="menu-outils"
                    accessibleText="Outils : sauvegarde, restauration, purge, connexion VigieChiro">
          <tooltip>
            <Tooltip text="Outils : sauvegarde, restauration, purge, connexion VigieChiro"/>
          </tooltip>
          <items>
            <MenuItem text="💾 Sauvegarder la base…" onAction="#sauvegarderBase"/>
            <MenuItem text="↩ Restaurer une sauvegarde…" onAction="#restaurerBase"/>
            <SeparatorMenuItem/>
            <MenuItem text="🧹 Purger les originaux importés…" onAction="#purgerOriginaux"/>
            <SeparatorMenuItem/>
            <!-- Préférence source des fiches espèces (#849) : coché = Wikipédia FR, décoché = GBIF (défaut).
                 Ne concerne que le repli hors chiroptères ; l'état est piloté par MainController. -->
            <CheckMenuItem fx:id="itemSourceWikipedia" text="Fiches espèces sur Wikipédia (sinon GBIF)"/>
            <SeparatorMenuItem/>
            <!-- Connexion VigieChiro (#741) : libellé rafraîchi par MainController à l'ouverture du menu
                 pour refléter l'état de connexion. -->
            <MenuItem fx:id="itemConnexion" text="🔌 Se connecter à VigieChiro…" onAction="#ouvrirModaleConnexion"/>
          </items>
        </MenuButton>
      </HBox>
    </top>

    <center>
      <VBox fx:id="zoneAccueil" styleClass="zone-accueil" spacing="0.0">
        <!-- Hero nocturne : bandeau en dégradé bleu nuit (identité « une nuit de capture »), avec
             titre, invite et tableau de bord de compteurs. Le filigrane décoratif déborde
             volontairement ; MainController clippe le hero à ses bornes. -->
        <StackPane fx:id="hero" styleClass="hero-nocturne">
          <FontIcon iconLiteral="fas-moon" styleClass="hero-filigrane" StackPane.alignment="TOP_RIGHT"/>
          <VBox styleClass="hero-contenu" alignment="CENTER" spacing="14.0">
            <Label styleClass="titre-accueil" text="Bienvenue dans VigieChiro PR Companion"/>
            <Label styleClass="sous-titre-accueil" wrapText="true" textAlignment="CENTER"
                   text="Deux entrées : collecter vos nuits d'enregistrement (sites &amp; passages) et exploiter vos espèces observées (biodiversité)."/>
            <!-- Bandeau de compteurs (tableau de bord) peuplé par MainController à partir des
                 IndicateurAccueil des features. Masqué tant qu'aucune donnée n'existe. -->
            <FlowPane fx:id="bandeauIndicateurs" styleClass="bandeau-indicateurs"
                      alignment="CENTER" hgap="12.0" vgap="12.0"/>
          </VBox>
        </StackPane>
        <!-- Zone des cartes d'activités : MainController y bâtit une section par prisme (en-tête +
             grille de cartes) à partir des ActiviteAccueil des features. -->
        <VBox styleClass="zone-cartes" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
          <FlowPane fx:id="cartesActivites" styleClass="sections-prismes"
                    alignment="TOP_CENTER" hgap="32.0" vgap="24.0"/>
        </VBox>
      </VBox>
    </center>

    <!--
      Barre de statut à 3 zones (#495) : gauche = contexte de l'écran, centre = résumé, droite =
      compteurs / état vivant. Les trois libellés sont alimentés par MainController depuis
      NavigationViewModel.zonesStatut. Le conteneur (barreStatut) est masqué tant qu'aucune zone n'a
      de contenu, pour ne pas laisser un bandeau sans information sur les écrans sans résumé.
    -->
    <bottom>
      <BorderPane fx:id="barreStatut" styleClass="pied-page">
        <left>
          <Label fx:id="piedGauche" styleClass="pied-zone, pied-gauche"/>
        </left>
        <center>
          <Label fx:id="piedCentre" styleClass="pied-zone, pied-centre" maxWidth="Infinity"/>
        </center>
        <right>
          <Label fx:id="piedDroite" styleClass="pied-zone, pied-droite"/>
        </right>
      </BorderPane>
    </bottom>
  </BorderPane>

  <!-- Liste déroulante des résultats de recherche (#144), superposée sous le champ (en haut à droite).
       Masquée tant qu'aucun résultat ; ne capte pas les clics hors de son contenu (pickOnBounds=false). -->
  <VBox fx:id="panneauResultats" styleClass="recherche-resultats"
        visible="false" managed="false" pickOnBounds="false"
        maxWidth="-Infinity" maxHeight="-Infinity" StackPane.alignment="TOP_RIGHT">
    <StackPane.margin>
      <Insets top="52.0" right="16.0"/>
    </StackPane.margin>
    <ListView fx:id="listeResultats" styleClass="recherche-liste" prefWidth="320.0" maxHeight="360.0"/>
  </VBox>
</StackPane>

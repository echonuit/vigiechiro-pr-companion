<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
  M-Import - assistant « Importer une nuit » (parcours P2), en page unique à 4 sections :
  dossier source -> inspection (lecture seule) -> rattachement -> action. Pur câblage : tous les
  contrôles sont liés aux propriétés de ImportationViewModel par ImportationController. La
  progression en arrière-plan et les cas limites (mélange, incohérence) viendront dans une tranche
  ultérieure.
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:id="racineImport"
      fx:controller="fr.univ_amu.iut.importation.view.ImportationController"
      stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css, @importation.css"
      styleClass="ecran-import"
      spacing="18.0">

  <!--
    Titre « Importer une nuit d'enregistrement » retiré (#693) : redondant avec le fil d'Ariane
    (« Importer une nuit »). La ligne de guidance de l'assistant est conservée (elle oriente
    l'utilisateur, ce n'est pas un résumé à déporter en barre de statut).
  -->
  <Label styleClass="sous-titre-page" wrapText="true"
         text="L'application prépare les séquences d'écoute à partir de la carte SD, sans jamais modifier vos fichiers d'origine."/>

  <!-- 1. Dossier source -->
  <VBox styleClass="carte-section" spacing="6.0">
    <Label text="1. Dossier source" styleClass="section-titre"/>
    <Label text="Le dossier de votre carte SD, une copie sur disque, ou une archive .zip. Vous pouvez aussi glisser-déposer un dossier ou un .zip n'importe où sur cet écran."
           styleClass="section-sous" wrapText="true"/>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
      <TextField fx:id="champDossier" editable="false" promptText="Aucun dossier sélectionné"
                 styleClass="champ-lecture-seule" HBox.hgrow="ALWAYS"/>
      <Button fx:id="boutonParcourir" text="Parcourir…" styleClass="bouton-secondaire"
              onAction="#parcourir">
        <graphic>
          <FontIcon iconLiteral="fas-folder-open"/>
        </graphic>
      </Button>
      <Button fx:id="boutonZip" text="Choisir un .zip…" styleClass="bouton-secondaire"
              onAction="#parcourirZip">
        <graphic>
          <FontIcon iconLiteral="fas-file-archive"/>
        </graphic>
      </Button>
    </HBox>
  </VBox>

  <!-- 2. Inspection -->
  <VBox fx:id="sectionInspection" styleClass="carte-section" spacing="6.0">
    <Label text="2. Inspection du dossier" styleClass="section-titre"/>
    <Label text="Lecture seule : aucun fichier n'est modifié pour l'instant."
           styleClass="section-sous"/>
    <Label fx:id="labelJournal" styleClass="insp-detail"/>
    <Label fx:id="labelReleve" styleClass="insp-detail"/>
    <Label fx:id="labelOriginaux" styleClass="insp-detail"/>
    <Label fx:id="labelNommage" styleClass="insp-detail"/>
    <!-- Avertissement « mélange » (#33), affiché seulement si plusieurs enregistreurs/nuits. -->
    <Label fx:id="labelMelange" styleClass="insp-avertissement" wrapText="true"
           visible="false" managed="false"/>
    <!-- Avertissement « incohérence » (#33) : journal/relevé en désaccord avec les WAV (série/date). -->
    <Label fx:id="labelIncoherence" styleClass="insp-incoherence" wrapText="true"
           visible="false" managed="false"/>
    <!-- Avertissement « nuit déjà importée » (#147) : un passage existe déjà pour cet enregistreur/date. -->
    <Label fx:id="labelNuitExistante" styleClass="insp-incoherence" wrapText="true"
           visible="false" managed="false"/>
    <!-- Découpage par nuit (#…) : une carte laissée tourner plusieurs nuits produit une ligne par nuit
         (chacune deviendra un passage). Visible seulement s'il y a plus d'une nuit. Décochez celles à
         exclure (ex. une nuit tronquée). -->
    <VBox fx:id="zoneNuits" spacing="6.0" visible="false" managed="false">
      <Label text="Plusieurs nuits détectées sur cette carte : chacune deviendra un passage distinct (même point, n° de passage consécutifs). Décochez celles que vous ne voulez pas importer."
             styleClass="section-sous" wrapText="true"/>
      <!-- La table des nuits est construite par programme (TableNuits) et insérée ici par le controller. -->
    </VBox>
  </VBox>

  <!-- 3. Rattachement -->
  <VBox styleClass="carte-section" spacing="10.0">
    <Label text="3. Rattachement de la nuit" styleClass="section-titre"/>
    <Label text="À quel site / point / passage du protocole cette nuit appartient-elle ?"
           styleClass="section-sous"/>
    <HBox spacing="14.0" alignment="BOTTOM_LEFT">
      <VBox spacing="4.0" HBox.hgrow="ALWAYS">
        <Label text="Site de suivi" styleClass="field-label"/>
        <ComboBox fx:id="comboSites" maxWidth="Infinity" promptText="Choisissez un site"/>
      </VBox>
      <VBox spacing="4.0">
        <Label text="Point d'écoute" styleClass="field-label"/>
        <ComboBox fx:id="comboPoints" prefWidth="150.0" promptText="Choisissez d'abord un site"/>
      </VBox>
      <VBox spacing="4.0">
        <Label text="Année" styleClass="field-label"/>
        <TextField fx:id="champAnnee" prefWidth="90.0"/>
      </VBox>
      <VBox spacing="4.0">
        <Label text="N° de passage" styleClass="field-label"/>
        <TextField fx:id="champPassage" prefWidth="100.0"/>
      </VBox>
    </HBox>
    <!-- Carte de confirmation (#154, lecture seule) : carré du site + ses points, le point choisi en
         surbrillance. Remplie en code par le controller (CarteRattachement) à chaque changement. -->
    <Label text="Vérifiez l'emplacement : carré du site et point choisi (en indigo)."
           styleClass="section-sous">
      <graphic>
        <FontIcon iconLiteral="fas-map-marker-alt"/>
      </graphic>
    </Label>
    <StackPane fx:id="zoneCarteRattachement" styleClass="zone-carte-rattachement"
               minHeight="170.0" prefHeight="190.0"/>
    <VBox styleClass="apercu-box" spacing="4.0">
      <Label text="Aperçu du préfixe appliqué aux fichiers :" styleClass="apercu-label">
        <graphic>
          <FontIcon iconLiteral="fas-file-alt"/>
        </graphic>
      </Label>
      <Label fx:id="labelApercu" styleClass="apercu-valeur" wrapText="true"/>
    </VBox>
    <!-- Discordance de préfixe (#111) : fichiers déjà préfixés ne correspondant pas au rattachement. -->
    <Label fx:id="labelPrefixeDiscordant" styleClass="insp-incoherence" wrapText="true"
           visible="false" managed="false"/>
    <!-- Pré-contrôle R5 (#108) : avertit d'un n° de passage déjà pris et propose le prochain libre. -->
    <HBox fx:id="zonePassageExistant" spacing="10.0" alignment="CENTER_LEFT"
          visible="false" managed="false">
      <Label fx:id="labelPassageExistant" styleClass="insp-incoherence" wrapText="true" HBox.hgrow="ALWAYS"/>
      <Button fx:id="boutonNumeroLibre" text="Utiliser ce n°" onAction="#utiliserNumeroLibre"/>
      <Button fx:id="boutonEcraser" text="Écraser et réimporter" styleClass="bouton-danger"
              onAction="#ecraserEtReimporter">
        <graphic>
          <FontIcon iconLiteral="fas-trash"/>
        </graphic>
      </Button>
    </HBox>
  </VBox>

  <!-- Option d'espace disque (#…) : conserver ou non une copie des originaux dans « bruts/ ». -->
  <VBox styleClass="carte-section" spacing="4.0">
    <CheckBox fx:id="caseConserverOriginaux" text="Conserver les originaux sur le disque"/>
    <Label styleClass="section-sous" wrapText="true"
           text="Décochez pour économiser l'espace disque : les enregistrements sont transformés directement depuis la carte SD, sans en copier une archive dans le dossier « bruts ». Les séquences d'écoute et le journal sont produits normalement ; seuls les fichiers d'origine ne sont pas conservés."/>
  </VBox>

  <!-- 4. Action -->
  <HBox spacing="14.0" alignment="CENTER_LEFT">
    <!-- Enveloppe : un Button désactivé n'affiche pas de Tooltip, on le pose sur ce StackPane (#789). -->
    <StackPane fx:id="enveloppeImporter">
      <Button fx:id="boutonImporter" text="Importer cette nuit" styleClass="bouton-primaire"
              onAction="#importer">
        <graphic>
          <FontIcon iconLiteral="fas-file-import"/>
        </graphic>
      </Button>
    </StackPane>
    <Label fx:id="labelMessage" styleClass="message-erreur" wrapText="true" HBox.hgrow="ALWAYS"/>
  </HBox>
  <!-- Progression déterminée (#33/#146), visible pendant la décompression d'un .zip ou l'import :
       barre « X/N », temps restant estimé, et bouton « Annuler » qui stoppe proprement. -->
  <VBox fx:id="zoneProgression" spacing="3.0" visible="false" managed="false">
    <HBox spacing="10.0" alignment="CENTER_LEFT">
      <ProgressBar fx:id="barreProgression" maxWidth="Infinity" progress="0.0" HBox.hgrow="ALWAYS"/>
      <Button fx:id="boutonAnnuler" text="Annuler" styleClass="bouton-secondaire" onAction="#annuler">
        <graphic>
          <FontIcon iconLiteral="fas-times"/>
        </graphic>
      </Button>
    </HBox>
    <Label fx:id="labelProgression" styleClass="insp-detail"/>
    <!-- Table de suivi par fichier (#947) : une ligne par original (copie -> transformation -> terminé /
         rejeté), en complément de la barre globale. Masquée tant qu'aucun plan n'est établi (donc pendant
         la décompression d'un .zip, qui ne suit pas les fichiers). -->
    <TableView fx:id="tableFichiers" prefHeight="190.0" visible="false" managed="false"/>
  </VBox>
  <Label fx:id="labelStatut" styleClass="message-succes" wrapText="true"/>
  <!-- Rapport d'import (#155) : fichiers rejetés (nom — raison), visible seulement s'il y en a. -->
  <VBox fx:id="zoneRejets" spacing="3.0" visible="false" managed="false">
    <Label text="Fichiers rejetés (non importés) :" styleClass="message-erreur">
      <graphic>
        <FontIcon iconLiteral="fas-exclamation-triangle"/>
      </graphic>
    </Label>
    <ListView fx:id="listeRejets" prefHeight="110.0"/>
  </VBox>
</VBox>


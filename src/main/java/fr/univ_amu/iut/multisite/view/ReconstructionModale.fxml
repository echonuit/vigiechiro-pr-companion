<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  Modale « Reconstruire un passage manquant » (#1396, suite de #1305), ouverte depuis le menu ☰ de la vue
  multi-sites : c'est là qu'on constate qu'une nuit manque, puisque c'est l'écran qui les liste toutes.

  Elle affiche les participations déposées sur VigieChiro qui n'ont AUCUN équivalent sur cette machine
  (déposées depuis un autre poste, avant l'application, ou après une réinstallation), et permet d'en
  rapatrier une en passage archivé. Le bouton se bloque - en disant pourquoi - quand le point d'écoute de
  la nuit n'existe pas encore ici : rattacher une nuit au mauvais point serait une donnée fausse.
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:id="racine"
      fx:controller="fr.univ_amu.iut.multisite.view.ReconstructionModaleController"
      stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css, @multisite.css"
      styleClass="modale-reconstruction"
      prefWidth="760.0"
      spacing="12.0">
  <!-- 760 et non 720 : les marges de la modale (18 de chaque côté, ajoutées avec sa règle de style)
       prennent sur la largeur utile, et les colonnes de la table débordaient d'une poignée de pixels -
       assez pour faire paraître une barre de défilement horizontale sous la table. -->

  <Label text="☁ Reconstruire un passage manquant" styleClass="titre-page"/>

  <!-- Texte sur UNE ligne : en FXML, un attribut multi-lignes conserve les retours et l'indentation,
       ce qui trouait le paragraphe au rendu. -->
  <Label text="Ces nuits existent sur Vigie-Chiro mais pas sur cette machine. Les reconstruire les rend consultables ici (observations comprises), mais sans les fichiers audio : la plateforme ne les restitue pas."
         styleClass="section-sous" wrapText="true"/>

  <TableView fx:id="tableOrphelines" prefHeight="240.0">
    <columns>
      <TableColumn fx:id="colCarre" text="Carré" prefWidth="80.0"/>
      <TableColumn fx:id="colPoint" text="Localité" prefWidth="80.0"/>
      <TableColumn fx:id="colNuit" text="Nuit" prefWidth="200.0"/>
      <TableColumn fx:id="colPointConnu" text="Point d'écoute" prefWidth="330.0"/>
    </columns>
    <placeholder>
      <Label fx:id="lblVide" text="Chargement des participations…" wrapText="true"/>
    </placeholder>
  </TableView>

  <!-- Constat (« 2 nuits manquent ») et refus sont deux choses : l'un s'affiche en neutre, l'autre en
       rouge. Les confondre ferait passer une information pour un incident. -->
  <!-- État de la liste chargée : permanent, non fermable. -->
  <Label fx:id="lblMessage" styleClass="section-sous" wrapText="true"/>

  <!-- Bandeau de retour partagé (ADR 0023) : remplace les libellés d'erreur et de compte rendu, dont les
       NOMS portaient la sévérité. Elle vit désormais dans la valeur (#1917). -->
  <HBox fx:id="bandeauRetour" styleClass="bandeau-retour" alignment="CENTER_LEFT" spacing="10.0">
    <Label fx:id="lblRetour" wrapText="true" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    <Button fx:id="btnFermerRetour" text="✕" styleClass="fermer-retour" accessibleText="Fermer le message"/>
  </HBox>

  <!-- Progression de l'opération longue (réseau + milliers d'insertions + import). Deux niveaux pour un
       import groupé (#1708) : le LOT (« Nuit X / N »), visible seulement pendant un lot, au-dessus de la
       NUIT COURANTE (visible pendant toute reconstruction et après un succès).

       Chaque niveau est un BLOC - son nom et son message sur une ligne, sa barre sur toute la largeur en
       dessous - comme les phases de la modale de réactivation. Une barre courte suivie de son message
       laissait celui-ci lui disputer sa largeur : le niveau au message le plus long se retrouvait avec la
       barre la plus COURTE, et deux barres inégales ne se comparent pas d'un coup d'oeil - ce qui est
       précisément ce qu'on demande à l'oeil quand on en empile deux. -->
  <VBox fx:id="zoneProgressionGlobale" spacing="4.0">
    <HBox alignment="TOP_LEFT" spacing="12.0">
      <Label text="Lot de nuits" styleClass="nom-de-phase" minWidth="-Infinity"/>
      <Label fx:id="lblProgressionGlobale" styleClass="section-sous" wrapText="true" HBox.hgrow="ALWAYS"/>
    </HBox>
    <ProgressBar fx:id="barreProgressionGlobale" maxWidth="Infinity"/>
  </VBox>
  <VBox fx:id="zoneProgression" spacing="4.0">
    <HBox alignment="TOP_LEFT" spacing="12.0">
      <Label text="Nuit en cours" styleClass="nom-de-phase" minWidth="-Infinity"/>
      <Label fx:id="lblProgression" styleClass="section-sous" wrapText="true" HBox.hgrow="ALWAYS"/>
    </HBox>
    <ProgressBar fx:id="barreProgression" maxWidth="Infinity"/>
  </VBox>

  <HBox alignment="CENTER_RIGHT" spacing="8.0">
    <Region HBox.hgrow="ALWAYS"/>
    <!-- « Annuler » n'apparaît que pendant l'opération : elle interrompt proprement, sans laisser de
         passage partiel (compensation côté service). -->
    <Button fx:id="boutonAnnuler" text="Annuler" styleClass="bouton-secondaire" onAction="#annuler"/>
    <Button fx:id="boutonFermer" text="Fermer" styleClass="bouton-secondaire" onAction="#fermer"/>
    <!-- Import groupé (#1708) : reconstruit toutes les nuits listées en une passe, avec double barre de
         progression et annulation. Grisé s'il n'y a aucune nuit à reconstruire. -->
    <Button fx:id="boutonReconstruireTout" text="Reconstruire tout" styleClass="bouton-secondaire"
            onAction="#reconstruireTout"/>
    <!-- Enveloppe non désactivée (#789) : un bouton grisé n'affiche aucun tooltip. C'est elle qui porte
         l'explication du blocage (aucune nuit choisie, ou point d'écoute inconnu ici). -->
    <StackPane fx:id="enveloppeReconstruire">
      <Button fx:id="boutonReconstruire" text="Reconstruire cette nuit" styleClass="bouton-primaire"
              onAction="#reconstruire"/>
    </StackPane>
  </HBox>
</VBox>

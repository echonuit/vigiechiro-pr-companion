<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  M-Multisite - vue agrégée des passages de tous les sites de l'utilisateur (parcours P5, SHOULD).
  Atteint depuis la carte « Vue multi-sites » de l'accueil (ActiviteMultisite).
  Pur câblage : le tableau des passages, les filtres (carré, statut, verdict, année), le tri, le
  double-clic d'ouverture d'un passage (contrat socle OuvrirPassage) et l'export CSV sont liés au
  MultisiteViewModel par le controller.
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.univ_amu.iut.multisite.view.MultisiteController"
      stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css, @multisite.css"
      styleClass="ecran-multisite"
      spacing="10.0">

  <!-- #341 : pas de titre de page (le fil d'Ariane du chrome indique déjà « … › Vue multi-sites »).
       On ne garde qu'une ligne fine de résumé pour récupérer de la hauteur, critique sur petit écran. -->
  <Label fx:id="lblResume" styleClass="sous-titre-page"/>

  <!-- Onglets de vues mémorisées « à la Notion » (#623) : un onglet par vue enregistrée + « + Vue ».
       Rempli en code par le composant partagé GestionnaireVues (le controller le construit). -->
  <FlowPane fx:id="barreOnglets" hgap="6.0" vgap="6.0" alignment="CENTER_LEFT" styleClass="barre-onglets"/>

  <!-- Barre de filtres « à la Notion » (#537 étape 6b) : recherche permanente + « + Filtre » (Carré,
       Statut, Verdict, Année) + puces des filtres actifs, puis le TRI (axe d'ordonnancement, pas un
       filtre) et Réinitialiser. Le menu « ☰ » des actions secondaires (Écouter, Exporter) est épinglé
       À DROITE. Les replis carte/tableau (#328) sont en bas ; l'édition des positions (#154, « ✎/💾 »)
       est superposée à la CARTE. -->
  <BorderPane styleClass="barre-filtres">
    <center>
      <HBox spacing="8.0" alignment="CENTER_LEFT" BorderPane.alignment="CENTER_LEFT">
        <TextField fx:id="champRecherche" promptText="Rechercher (carré, point, date…)" prefWidth="220.0"
                   accessibleText="Rechercher dans les passages"/>
        <MenuButton fx:id="menuAjoutFiltre" text="+ Filtre" styleClass="menu-ajout-filtre"
                    accessibleText="Ajouter un filtre"/>
        <!-- hgrow + maxWidth : les puces occupent la largeur restante et s'alignent horizontalement (sinon le
             FlowPane se limite à sa largeur préférée et les empile). Tri/Réinitialiser s'ancrent à droite. -->
        <FlowPane fx:id="pucesFiltres" hgap="6.0" vgap="6.0" alignment="CENTER_LEFT"
                  HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <ComboBox fx:id="choixTri" accessibleText="Trier les passages"/>
        <Button fx:id="boutonReinitialiser" text="Réinitialiser" onAction="#reinitialiser"/>
      </HBox>
    </center>
    <right>
      <MenuButton fx:id="menuActions" text="☰" styleClass="menu-actions" BorderPane.alignment="CENTER">
        <BorderPane.margin>
          <Insets left="8.0"/>
        </BorderPane.margin>
        <items>
          <MenuItem fx:id="itemEcouterPassage" text="🎧 Écouter le passage sélectionné" onAction="#ecouterPassage"/>
          <MenuItem fx:id="itemEcouterLot" text="🎧 Écouter le lot filtré" onAction="#ecouterLot"/>
          <MenuItem fx:id="itemExporter" text="📤 Exporter…" onAction="#exporter"/>
        </items>
      </MenuButton>
    </right>
  </BorderPane>

  <!-- Carte (sites + points) à gauche, tableau des passages à droite (#152). La carte est remplie en
       code par le controller (composant CarteSites, dépendance Gluon Maps). Le repli d'un côté
       (carte ou tableau) est piloté par la barre du bas (#328, #370). -->
  <SplitPane fx:id="splitCarteTableau" dividerPositions="0.42" styleClass="split-carte-tableau"
             VBox.vgrow="ALWAYS">
      <items>
        <StackPane fx:id="zoneCarte" styleClass="zone-carte"/>
        <VBox fx:id="panneauTableau" spacing="6.0">
          <TableView fx:id="tableLignes" VBox.vgrow="ALWAYS">
            <columns>
              <TableColumn fx:id="colCarre" text="Carré" prefWidth="90.0"/>
              <TableColumn fx:id="colPoint" text="Point" prefWidth="70.0"/>
              <TableColumn fx:id="colAnnee" text="Année" prefWidth="70.0"/>
              <TableColumn fx:id="colNumero" text="N° passage" prefWidth="90.0"/>
              <TableColumn fx:id="colDate" text="Date" prefWidth="120.0"/>
              <TableColumn fx:id="colStatut" text="Statut" prefWidth="120.0"/>
              <TableColumn fx:id="colVerdict" text="Verdict" prefWidth="100.0"/>
            </columns>
          </TableView>
          <Label text="Astuce : double-cliquez une ligne pour ouvrir l'écran du passage."
                 styleClass="section-sous"/>
        </VBox>
      </items>
  </SplitPane>

  <!-- #370 : replis carte/tableau placés EN BAS, chacun à l'extrémité sous le panneau qu'il masque
       (« ◀ Carte » à gauche, « Tableau ▶ » à droite). Libellé, info-bulle et état actif/désactivé sont
       gérés par MultisiteController#majPoignees (interdit de tout replier). -->
  <BorderPane styleClass="barre-replis">
    <left>
      <Button fx:id="boutonReplierCarte" styleClass="bouton-repli" onAction="#basculerCarte"/>
    </left>
    <right>
      <Button fx:id="boutonReplierTableau" styleClass="bouton-repli" onAction="#basculerTableau"/>
    </right>
  </BorderPane>

  <Label fx:id="lblMessage" styleClass="message-erreur" wrapText="true"/>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  M-Multisite - vue agrégée des passages de tous les sites de l'utilisateur (parcours P5, SHOULD).
  Atteint depuis la carte « Vue multi-sites » de l'accueil (ActiviteMultisite).
  Pur câblage : le tableau des passages, les filtres (carré, statut, verdict, année), le tri, le
  double-clic d'ouverture d'un passage (contrat socle OuvrirPassage) et l'export CSV sont liés au
  MultisiteViewModel par le controller.
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.univ_amu.iut.multisite.view.MultisiteController"
      stylesheets="@../../commun/view/palette.css, @multisite.css"
      styleClass="ecran-multisite"
      spacing="10.0">

  <!-- #341 : pas de titre de page (le fil d'Ariane du chrome indique déjà « … › Vue multi-sites »).
       On ne garde qu'une ligne fine de résumé pour récupérer de la hauteur, critique sur petit écran. -->
  <Label fx:id="lblResume" styleClass="sous-titre-page"/>

  <!-- #340 : barre réorganisée en DEUX rangées pour la lisibilité (filtres/tri/actions/édition/replis
       étaient mélangés sur une seule ligne). Rangée 1 = filtrer & trier ; rangée 2 = actions, puis,
       après un séparateur, les replis d'affichage. Le tout dans une seule boîte « barre-filtres ». -->
  <VBox spacing="6.0" styleClass="barre-filtres">
    <!-- Rangée 1 : filtrer & trier -->
    <FlowPane hgap="8.0" vgap="6.0" alignment="CENTER_LEFT">
      <Label text="Carré :" styleClass="section-sous"/>
      <TextField fx:id="champCarre" promptText="640380" prefWidth="100.0"/>
      <Label text="Statut :" styleClass="section-sous"/>
      <ComboBox fx:id="choixStatut"/>
      <Label text="Verdict :" styleClass="section-sous"/>
      <ComboBox fx:id="choixVerdict"/>
      <Label text="Année :" styleClass="section-sous"/>
      <TextField fx:id="champAnnee" promptText="2026" prefWidth="70.0"/>
      <Label text="Tri :" styleClass="section-sous"/>
      <ComboBox fx:id="choixTri"/>
      <Button fx:id="boutonReinitialiser" text="Réinitialiser" onAction="#reinitialiser"/>
    </FlowPane>
    <!-- Rangée 2 : actions | affichage -->
    <FlowPane hgap="8.0" vgap="6.0" alignment="CENTER_LEFT">
      <Button fx:id="boutonGererVues" text="⭐ Vues…" onAction="#gererVues"/>
      <Button fx:id="boutonExporter" text="📤 Exporter…" onAction="#exporter"/>
      <!-- Édition des positions (#154) : le toggle passe la carte en mode déplacement (glisser un marqueur,
           clampé à son carré) ; le bouton enregistre les déplacements en attente (inactif sinon, visible en
           édition seulement). Décliquer le toggle avec des changements non enregistrés ouvre une alerte. -->
      <ToggleButton fx:id="boutonEditerPositions" text="✎ Éditer les positions" onAction="#basculerEdition"/>
      <Button fx:id="boutonEnregistrerPositions" text="💾 Enregistrer les positions" onAction="#enregistrerPositions"/>
      <Separator orientation="VERTICAL"/>
      <!-- Repli carte/tableau (#328) : libellé et état gérés par MultisiteController#majPoignees. -->
      <Button fx:id="boutonReplierCarte" onAction="#basculerCarte"/>
      <Button fx:id="boutonReplierTableau" onAction="#basculerTableau"/>
    </FlowPane>
  </VBox>

  <!-- Carte (sites + points) à gauche, tableau des passages à droite (#152). La carte est remplie en
       code par le controller (composant CarteSites, dépendance Gluon Maps). Le repli d'un côté
       (carte ou tableau) est piloté par les boutons de la barre d'actions ci-dessus (#328). -->
  <SplitPane fx:id="splitCarteTableau" dividerPositions="0.42" styleClass="split-carte-tableau"
             VBox.vgrow="ALWAYS">
      <items>
        <StackPane fx:id="zoneCarte" styleClass="zone-carte"/>
        <VBox fx:id="panneauTableau" spacing="6.0">
          <TableView fx:id="tableLignes" VBox.vgrow="ALWAYS">
            <columns>
              <TableColumn fx:id="colCarre" text="Carré" prefWidth="90.0"/>
              <TableColumn fx:id="colPoint" text="Point" prefWidth="70.0"/>
              <TableColumn fx:id="colAnnee" text="Année" prefWidth="70.0"/>
              <TableColumn fx:id="colNumero" text="N° passage" prefWidth="90.0"/>
              <TableColumn fx:id="colDate" text="Date" prefWidth="120.0"/>
              <TableColumn fx:id="colStatut" text="Statut" prefWidth="120.0"/>
              <TableColumn fx:id="colVerdict" text="Verdict" prefWidth="100.0"/>
            </columns>
          </TableView>
          <Label text="Astuce : double-cliquez une ligne pour ouvrir l'écran du passage."
                 styleClass="section-sous"/>
        </VBox>
      </items>
  </SplitPane>

  <Label fx:id="lblMessage" styleClass="message-erreur" wrapText="true"/>
</VBox>

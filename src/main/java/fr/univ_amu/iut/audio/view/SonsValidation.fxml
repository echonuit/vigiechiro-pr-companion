<?xml version="1.0" encoding="UTF-8"?>

<?import fr.nedjar.vigiechiro.audio.AudioView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckMenuItem?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  Sons & validation - vue audio unifiée (#audio) : écouter, valider / corriger et archiver en référence
  un ensemble d'observations, quelle que soit sa provenance (un passage, un lot, une espèce, le corpus de
  référence). Disposition EMPILÉE (alignée sur l'analyse) : la table en haut, l'écoute pleine largeur en
  bas - le spectrogramme (temps en X) profite de toute la largeur. Les actions propres à la source (import
  CSV / export _Vu d'un passage, export bibliothèque des références) vivent dans le menu « ☰ ».
  Pur câblage : table, sélection, audio, revue et actions sont liés au AudioViewModel par le controller.
-->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="fr.univ_amu.iut.audio.view.SonsValidationController"
           stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css, @sons-validation.css"
           fx:id="hoteOccupation">
  <!-- Hôte d'occupation (#1214) : voile « … en cours » pendant le chargement des sons d'un passage. -->
  <VBox fx:id="racine"
      styleClass="ecran-audio"
      spacing="6.0">

  <!-- Pas de bandeau de titre ici : le nom d'écran est déjà porté par le fil d'Ariane, et le résumé
       (compteurs de revue) est déporté dans la barre de statut via ResumeStatut (gain d'espace vertical). -->

  <!-- Onglets de vues mémorisées « à la Notion » (#623) : un onglet par combinaison de filtres enregistrée.
       Rempli en code par le composant partagé GestionnaireVues (le controller le construit). -->
  <FlowPane fx:id="barreOnglets" hgap="6.0" vgap="6.0" alignment="CENTER_LEFT" styleClass="barre-onglets"/>

  <!-- Barre de filtres « à la Notion » (#470/#471) : recherche texte permanente + « + Filtre » (menu des
       critères) + puces des filtres actifs. Actions propres à la source épinglées à droite dans « ☰ ». -->
  <BorderPane styleClass="barre-filtres">
    <center>
      <HBox spacing="8.0" alignment="CENTER_LEFT" BorderPane.alignment="CENTER_LEFT">
        <TextField fx:id="champRecherche" promptText="Rechercher (espèce, fichier, commentaire…)"
                   accessibleText="Rechercher dans les observations" prefWidth="240.0"/>
        <MenuButton fx:id="menuAjoutFiltre" text="+ Filtre" styleClass="menu-ajout-filtre"
                    accessibleText="Ajouter un filtre"/>
        <!-- hgrow + maxWidth : le FlowPane des puces occupe toute la largeur restante de la rangée, sinon il
             se limite à sa largeur préférée (~prefWrapLength) et empile les puces verticalement. -->
        <FlowPane fx:id="pucesFiltres" hgap="6.0" vgap="6.0" alignment="CENTER_LEFT"
                  HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
      </HBox>
    </center>
    <right>
      <MenuButton fx:id="menuActions" text="☰" styleClass="menu-actions" BorderPane.alignment="CENTER"
                  accessibleText="Actions : voir sur la carte, importer, exporter">
        <tooltip>
          <Tooltip text="Actions : voir sur la carte, importer, exporter"/>
        </tooltip>
        <items>
          <MenuItem fx:id="itemVoirCarte" text="🗺 Voir sur la carte" onAction="#voirSurCarte"/>
          <MenuItem fx:id="itemFicheEspece" text="Fiche de l'espèce"/>
          <SeparatorMenuItem/>
          <MenuItem fx:id="itemImporter" text="📥 Importer un CSV Tadarida…" onAction="#importer"/>
          <MenuItem fx:id="itemImporterVigieChiro" text="☁ Importer depuis Vigie-Chiro…" onAction="#importerDepuisVigieChiro"/>
          <MenuItem fx:id="itemPublierCorrections" text="☁ Publier les corrections vers Vigie-Chiro…" onAction="#publierCorrections"/>
          <MenuItem fx:id="itemOuvrirVigieChiro" text="🌐 Ouvrir les données sur Vigie-Chiro" onAction="#ouvrirDonneesVigieChiro"/>
          <CheckMenuItem fx:id="itemInclureMode" text="Inclure le mode de validation à l'export _Vu"/>
          <MenuItem fx:id="itemExporterVu" text="📤 Exporter _Vu…" onAction="#exporterVu"/>
          <MenuItem fx:id="itemExporterObservations" text="📤 Exporter les observations (CSV)…" onAction="#exporterObservations"/>
          <MenuItem fx:id="itemExporterBiblio" text="📤 Exporter la bibliothèque…" onAction="#exporterBibliotheque"/>
        </items>
      </MenuButton>
    </right>
  </BorderPane>

  <!-- Bandeau de retour d'opération (succès / erreur d'import…), juste sous la barre pour être vu tout
       de suite. Masqué (non managé) tant qu'aucun retour n'est présent : il n'occupe alors aucune place.
       Une croix permet de le fermer une fois lu. -->
  <HBox fx:id="bandeauRetour" styleClass="bandeau-retour" alignment="CENTER_LEFT" spacing="10.0">
    <Label fx:id="lblRetour" wrapText="true" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    <Button fx:id="btnFermerRetour" text="✕" styleClass="fermer-retour" accessibleText="Fermer le message"/>
  </HBox>

  <!-- Avancement / bilan de l'import VigieChiro (axe 4.2), masqué tant qu'aucun import n'a été lancé. -->
  <Label fx:id="lblImportVigieChiro" styleClass="audio-message" wrapText="true" maxWidth="Infinity"
         visible="false" managed="false"/>

  <!-- Avancement / bilan de la publication des corrections (#723), masqué tant que rien n'a été lancé. -->
  <Label fx:id="lblPublierCorrections" styleClass="audio-message" wrapText="true" maxWidth="Infinity"
         visible="false" managed="false"/>

  <!-- Disponibilité de l'audio du passage (#1301) : « passage archivé » ou « audio partiel n/total »,
       avec la voie de retour (réimport). Masqué (non managé) quand l'audio est complet. -->
  <Label fx:id="lblBandeauArchive" styleClass="audio-message" wrapText="true" maxWidth="Infinity"
         visible="false" managed="false"/>

  <SplitPane fx:id="separateur" orientation="VERTICAL" dividerPositions="0.5" VBox.vgrow="ALWAYS">

    <!-- Haut : la table des observations, pleine largeur. -->
    <StackPane>
      <TableView fx:id="tableObservations">
        <columns>
          <!-- Ordre par défaut voulu pour les tables à espèces : contexte (Date + Passage/Carré/Point,
               masqués pour un passage unique) puis fichier, puis identification, statut et indicateurs. -->
          <TableColumn fx:id="colDate" text="Date" prefWidth="110.0"/>
          <TableColumn fx:id="colHeure" text="Heure" prefWidth="80.0"/>
          <TableColumn fx:id="colPassage" text="Passage" prefWidth="150.0"/>
          <TableColumn fx:id="colCarre" text="Carré" prefWidth="90.0"/>
          <TableColumn fx:id="colPoint" text="Point" prefWidth="70.0"/>
          <TableColumn fx:id="colFichier" text="Fichier" prefWidth="200.0"/>
          <TableColumn fx:id="colTadarida" text="Proposition Tadarida" prefWidth="180.0"/>
          <TableColumn fx:id="colProba" text="Proba." prefWidth="70.0"/>
          <TableColumn fx:id="colObservateur" text="Votre taxon" prefWidth="180.0"/>
          <TableColumn fx:id="colCertitude" text="Certitude" prefWidth="90.0"/>
          <TableColumn fx:id="colValidateur" text="Avis du validateur" prefWidth="180.0"/>
          <TableColumn fx:id="colFrequence" text="Fréquence" prefWidth="100.0"/>
          <TableColumn fx:id="colFme" text="FME" prefWidth="90.0"/>
          <TableColumn fx:id="colFreqTerminale" text="Fréq. term." prefWidth="100.0"/>
          <TableColumn fx:id="colDebut" text="Début" prefWidth="80.0"/>
          <TableColumn fx:id="colDuree" text="Durée" prefWidth="80.0"/>
          <TableColumn fx:id="colStatut" text="Statut" prefWidth="110.0"/>
          <TableColumn fx:id="colReference" text="⭐" prefWidth="50.0"/>
          <TableColumn fx:id="colCommentaire" text="💬" prefWidth="50.0"/>
          <TableColumn fx:id="colFil" text="🗣" prefWidth="50.0"/>
        </columns>
      </TableView>
      <Label fx:id="lblVide" styleClass="audio-vide" wrapText="true"/>
    </StackPane>

    <!-- Bas : écoute pleine largeur + revue. minHeight pour que le spectrogramme ne soit jamais écrasé
         par la table quand on tire le diviseur (cf. incident #329 : vgrow qui aplatit l'AudioView). -->
    <VBox fx:id="panneauEcoute" styleClass="panneau-ecoute" spacing="6.0" minHeight="210.0">
      <!-- Détail de l'observation retiré du panneau (redondant avec la table) : il sera rendu dans la
           barre de statut lors de la structuration en 3 zones (#495). Le VM garde detailProperty prête. -->
      <!-- L'AudioView et son encart de remplacement (#1301) partagent un StackPane : quand le fichier
           de la séquence sélectionnée n'est plus sur disque (passage archivé, disque incomplet), le
           lecteur est remplacé par une explication au lieu de rester inerte. Pas de ScrollPane autour
           de l'AudioView (piège du spectrogramme noir, #329). -->
      <!-- Le lecteur et le fil de discussion (#1417) cote a cote : un fil se lit EN ecoutant. Le panneau
           reste masque (visible+managed a false) tant qu'aucun message n'existe sur la ligne selectionnee,
           ce qui est le cas de l'immense majorite des detections : il ne vole donc pas de largeur au
           spectrogramme pour ne rien dire. -->
      <HBox spacing="8.0" VBox.vgrow="ALWAYS">
      <StackPane HBox.hgrow="ALWAYS" minHeight="150.0">
        <AudioView fx:id="audioView" minHeight="150.0"/>
        <VBox fx:id="encartAudioManquant" alignment="CENTER" spacing="4.0" styleClass="audio-vide"
              visible="false" managed="false">
          <Label text="Audio non conservé sur le disque" styleClass="audio-vide"/>
          <Label wrapText="true" maxWidth="560.0"
                 text="Cette séquence n'est plus écoutable : son fichier a été supprimé (passage archivé ou disque incomplet). Les observations restent consultables et modifiables ; pour réécouter, réimportez les fichiers d'origine."/>
        </VBox>
      </StackPane>
      <StackPane fx:id="hoteDiscussion" managed="false" visible="false"/>
      </HBox>
      <!-- Chaque bouton d'action est enrobé d'un StackPane : un Button désactivé n'affiche pas de Tooltip,
           on pose donc l'explication du blocage sur l'enveloppe qui, elle, reçoit le survol (#789). -->
      <HBox spacing="8.0" alignment="CENTER_LEFT" styleClass="barre-actions">
        <ComboBox fx:id="choixMode" accessibleText="Mode de revue" promptText="Mode de revue"/>
        <StackPane fx:id="enveloppeValider">
          <Button fx:id="btnValider" text="✔ Valider" onAction="#valider"/>
        </StackPane>
        <Region prefWidth="12.0"/>
        <ComboBox fx:id="choixTaxon" promptText="Choisir un taxon…"/>
        <StackPane fx:id="enveloppeCorriger">
          <Button fx:id="btnCorriger" text="✎ Corriger" onAction="#corriger"/>
        </StackPane>
        <StackPane fx:id="enveloppeCertitude">
          <MenuButton fx:id="menuCertitude" text="Certitude"/>
        </StackPane>
        <Region HBox.hgrow="ALWAYS"/>
        <StackPane fx:id="enveloppeDouteux">
          <Button fx:id="btnDouteux" onAction="#basculerDouteux"/>
        </StackPane>
        <StackPane fx:id="enveloppeReference">
          <Button fx:id="btnReference" onAction="#basculerReference"/>
        </StackPane>
      </HBox>
      <!-- Légende des raccourcis de revue au clavier (#796) : câblés (RevueClavier) mais indécouvrables
           sans cette aide visible. -->
      <Label styleClass="section-sous" wrapText="true"
             text="Raccourcis clavier : Entrée valider · R référence · D douteux · 1/2/3 certitude · N suivant à revoir"/>
      <!-- Astuce de découvrabilité du glisser-déposer (#1015) : visible seulement quand la source offre
           le workflow Tadarida (le controller la pilote à chaque ouverture) ; ailleurs, rien n'encombre. -->
      <Label fx:id="lblAstuceDepot" styleClass="section-sous" wrapText="true" visible="false" managed="false"
             text="Astuce : déposez un fichier CSV Tadarida n'importe où sur cet écran pour l'importer."/>
    </VBox>

  </SplitPane>
</VBox>
</StackPane>

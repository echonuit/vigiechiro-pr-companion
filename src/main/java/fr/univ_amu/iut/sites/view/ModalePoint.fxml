<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  Modale d'ajout / d'édition d'un point d'écoute (ouverte depuis M-Site-detail dans un Stage
  modal). Tous les champs sont liés en bidirectionnel au PointEditViewModel ; le titre, le libellé
  du bouton, son activation, le message d'erreur et le surlignage du code invalide (R2) sont
  pilotés par ce ViewModel.
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:id="racine"
      fx:controller="fr.univ_amu.iut.sites.view.ModalePointController"
      stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css, @sites.css"
      styleClass="modale-point"
      prefWidth="560.0"
      spacing="10.0">

  <Label fx:id="titreModale" styleClass="modale-titre"/>

  <Label text="IDENTIFICATION" styleClass="section-label"/>
  <HBox spacing="10.0" alignment="CENTER_LEFT">
    <!-- minWidth=USE_PREF_SIZE : sans cela, la HBox rogne le libellé (« Code du poi… »). -->
    <Label text="Code du point *" styleClass="field-label" minWidth="-Infinity"/>
    <TextField fx:id="champCode" promptText="A1" prefWidth="110.0"/>
  </HBox>
  <!-- Sur sa propre ligne : dans la HBox, la consigne était rognée (« (ex. A1, … »). -->
  <Label text="1 lettre majuscule + 1 ou plusieurs chiffres (ex. A1, Z41)" styleClass="field-hint"
         wrapText="true"/>
  <!-- Bandeau de retour partagé (ADR 0023) : remplace le libellé « messageErreur », dont le NOM portait
       la sévérité et interdisait donc d'y dire autre chose qu'un échec (#1917). -->
  <HBox fx:id="bandeauRetour" styleClass="bandeau-retour" alignment="CENTER_LEFT" spacing="10.0">
    <Label fx:id="lblRetour" wrapText="true" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    <Button fx:id="btnFermerRetour" text="✕" styleClass="fermer-retour" accessibleText="Fermer le message"/>
  </HBox>

  <Label text="Descriptif (optionnel)" styleClass="field-label"/>
  <TextArea fx:id="champDescription" prefRowCount="2" wrapText="true"
            promptText="Notes terrain (« près du chêne, à 30 m du chemin »)"/>

  <Label text="GÉOLOCALISATION (OPTIONNELLE)" styleClass="section-label"/>
  <HBox spacing="14.0">
    <VBox spacing="2.0">
      <Label text="Latitude" styleClass="field-label"/>
      <TextField fx:id="champLatitude" promptText="43.5298 ou 43°31'47&quot;N" prefWidth="180.0"/>
    </VBox>
    <VBox spacing="2.0">
      <Label text="Longitude" styleClass="field-label"/>
      <TextField fx:id="champLongitude" promptText="5.4474 ou 5°26'51&quot;E" prefWidth="180.0"/>
    </VBox>
  </HBox>
  <Label styleClass="field-hint" wrapText="true"
         text="Degrés décimaux (43.5298 ; virgule tolérée) ou degrés/minutes/secondes (43°31'47&quot;N) : collez depuis n'importe quelle source. Latitude −90..90, longitude −180..180."/>

  <!-- Contrôle du carré STOC (#733) : ce que la grille officielle dit de la position saisie - elle confirme
       le carré du site, ou signale que le point tombe ailleurs. Masqué tant qu'il n'y a rien à dire (hors
       ligne : silence, la saisie manuelle reste entière). -->
  <Label fx:id="messageCarre" wrapText="true" managed="false" visible="false"/>

  <!-- Carte-outil de saisie GPS (#153) : remplie par le controller (composant CarteSites, Gluon Maps),
       centrée sur le carré du site. Glisser le marqueur OU saisir les champs : les deux restent
       synchronisés. Sans GPS, le marqueur démarre au centre du carré (position approximative à caler). -->
  <StackPane fx:id="zoneCarte" styleClass="zone-carte-modale" minHeight="220.0" prefHeight="240.0"/>
  <Label text="Astuce : glissez le marqueur sur la carte pour fixer la position (ou saisissez les coordonnées)."
         styleClass="field-hint" wrapText="true"/>

  <HBox alignment="CENTER_RIGHT" spacing="8.0">
    <Region HBox.hgrow="ALWAYS"/>
    <Button text="Annuler" styleClass="bouton-secondaire" onAction="#annuler"/>
    <Button fx:id="boutonValider" text="+ Ajouter" styleClass="bouton-primaire"
            onAction="#valider"/>
  </HBox>
</VBox>

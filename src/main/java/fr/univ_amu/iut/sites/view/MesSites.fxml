<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
  M-Sites - « Mes sites de suivi » (écran d'accueil de la feature sites).
  Le bandeau (titre + sous-titre + bouton « + Nouveau site ») et l'ossature sont déclarés ici ;
  les cartes de sites (nombre variable) sont bâties en code par MesSitesController, qui bascule
  aussi entre la liste (zoneListe) et l'état vide (etatVide) selon SitesViewModel.videProperty().
-->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="fr.univ_amu.iut.sites.view.MesSitesController"
           stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css, @sites.css"
           fx:id="hoteOccupation">
  <!-- Hôte d'occupation (#1212) : voile « … en cours » pendant le chargement des cartes et la
       synchronisation VigieChiro. -->
  <VBox styleClass="ecran-sites" spacing="16.0">

  <!--
    En-tête réduit à son slot d'actions (#693) : le titre « Mes sites de suivi » est redondant avec le
    fil d'Ariane et le résumé (« N sites déclarés… ») est déporté en barre de statut par le controller.
  -->
  <HBox styleClass="entete-actions" alignment="CENTER_RIGHT" spacing="8.0">
    <!-- Synchronisation à la demande (#1045) : masqué quand la passerelle VigieChiro est absente. -->
    <Button fx:id="btnSyncVigieChiro" text="Récupérer depuis Vigie-Chiro" styleClass="bouton-secondaire"
            onAction="#recupererDepuisVigieChiro"/>
    <Button text="+ Nouveau site" styleClass="bouton-primaire" onAction="#nouveauSite"/>
  </HBox>

  <!-- Erreur de chargement (#795) : affichée en rouge et masquée tant qu'il n'y a pas d'erreur (un échec
       de lecture des sites restait auparavant silencieux). -->
  <!-- Bandeau de retour partagé (ADR 0023) : sévérité + fermeture. -->
  <HBox fx:id="bandeauRetour" styleClass="bandeau-retour" alignment="CENTER_LEFT" spacing="10.0">
    <Label fx:id="lblRetour" wrapText="true" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    <Button fx:id="btnFermerRetour" styleClass="fermer-retour" accessibleText="Fermer le message">
      <graphic>
        <FontIcon iconLiteral="fas-times"/>
      </graphic>
    </Button>
  </HBox>

  <!-- Résultat de la synchronisation à la demande (#1045), masqué tant qu'aucune n'a eu lieu. -->
  <Label fx:id="lblSynchro" styleClass="message-synchro" wrapText="true" visible="false" managed="false"/>

  <ScrollPane fx:id="zoneListe" fitToWidth="true" styleClass="zone-liste" VBox.vgrow="ALWAYS">
    <VBox fx:id="listeCartes" styleClass="liste-cartes" spacing="12.0"/>
  </ScrollPane>

  <VBox fx:id="etatVide" styleClass="etat-vide" alignment="CENTER" spacing="10.0"
        VBox.vgrow="ALWAYS">
    <Label  styleClass="etat-vide-icone">
      <graphic>
        <FontIcon iconLiteral="fas-globe"/>
      </graphic>
    </Label>
    <Label text="Bienvenue ! Commencez par déclarer votre premier site."
           styleClass="etat-vide-titre"/>
    <Label text="Un site = un carré Vigie-Chiro (6 chiffres) avec un ou plusieurs points d'écoute."
           styleClass="etat-vide-sous"/>
    <Button text="+ Ajouter mon premier site de suivi" styleClass="bouton-primaire-grand"
            onAction="#nouveauSite"/>
    <VBox styleClass="hint-box" maxWidth="660.0" spacing="4.0">
      <Label text="Vous n'avez pas encore créé votre site sur Vigie-Chiro ?"
             styleClass="hint-titre">
        <graphic>
          <FontIcon iconLiteral="fas-lightbulb"/>
        </graphic>
      </Label>
      <Label wrapText="true" styleClass="hint-txt"
             text="Le carré et les points doivent d'abord être déclarés sur le portail web
                   vigiechiro.herokuapp.com, puis saisis ici (n° de carré + codes points)."/>
    </VBox>
  </VBox>
  </VBox>
</StackPane>

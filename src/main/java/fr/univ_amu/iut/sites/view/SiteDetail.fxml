<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
  M-Site-detail - fiche d'un site (identité + points d'écoute + tableau des passages).
  Le bandeau d'infos clés et le tableau sont déclarés ici (valeurs liées aux propriétés du
  SiteDetailViewModel) ; les cartes de points (nombre variable) sont bâties en code par
  SiteDetailController. La navigation (retour, modales, suppression) passe par NavigationSites.
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.univ_amu.iut.sites.view.SiteDetailController"
      stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css, @sites.css"
      styleClass="ecran-detail"
      spacing="14.0">

  <!--
    En-tête réduit à ses actions (#693) : le titre (nom du site) et le sous-titre (commune, protocole)
    sont déportés en barre de statut par le controller (zones gauche/centre). Le fil d'Ariane porte déjà
    le carré ; les actions restent en tête d'écran.
  -->
  <HBox styleClass="entete-actions" alignment="CENTER_RIGHT">
    <Button fx:id="boutonImporterNuit" text="Importer une nuit" styleClass="bouton-primaire"
            onAction="#importerNuit">
      <graphic>
        <FontIcon iconLiteral="fas-file-import"/>
      </graphic>
      <tooltip><Tooltip text="Ouvre l'assistant d'import avec ce site déjà pré-rattaché."/></tooltip>
    </Button>
    <Button fx:id="boutonVoirCarte" text="Voir sur la carte" styleClass="bouton-secondaire"
            onAction="#voirSurCarte">
      <graphic>
        <FontIcon iconLiteral="fas-map"/>
      </graphic>
      <tooltip><Tooltip text="Ouvre la carte multi-sites centrée sur ce carré."/></tooltip>
    </Button>
    <!-- Enveloppe (#789) : le tooltip d'explication doit survivre à la désactivation du bouton. -->
    <StackPane fx:id="enveloppeOuvrirPortail">
      <Button fx:id="boutonOuvrirPortail" text="Ouvrir sur Vigie-Chiro" styleClass="bouton-secondaire"
              onAction="#ouvrirSurVigieChiro">
        <graphic>
          <FontIcon iconLiteral="fas-globe"/>
        </graphic>
      </Button>
    </StackPane>
    <Button fx:id="boutonModifier" text="Modifier" styleClass="bouton-secondaire"
            onAction="#modifierSite">
      <graphic>
        <FontIcon iconLiteral="fas-pen"/>
      </graphic>
    </Button>
    <!-- Enveloppe : un Tooltip ne s'affiche pas sur un Button désactivé ; on l'installe donc sur ce
         conteneur (qui, lui, reçoit le survol) pour expliquer pourquoi la suppression est bloquée. -->
    <StackPane fx:id="enveloppeSupprimer">
      <Button fx:id="boutonSupprimer" text="Supprimer" styleClass="bouton-danger"
              onAction="#supprimerSite">
        <graphic>
          <FontIcon iconLiteral="fas-trash"/>
        </graphic>
      </Button>
    </StackPane>
    <MenuButton fx:id="menuOutils" styleClass="menu-actions" accessibleText="Outils : colonnes">
      <graphic>
        <FontIcon iconLiteral="fas-bars"/>
      </graphic>
    </MenuButton>
  </HBox>

  <HBox styleClass="bandeau-infos" spacing="0.0">
    <VBox styleClass="bandeau-cellule" HBox.hgrow="ALWAYS">
      <Label text="N° DE CARRÉ" styleClass="bandeau-label"/>
      <Label fx:id="valNumeroCarre" styleClass="bandeau-valeur"/>
    </VBox>
    <VBox styleClass="bandeau-cellule" HBox.hgrow="ALWAYS">
      <Label text="DÉPARTEMENT" styleClass="bandeau-label"/>
      <Label fx:id="valDepartement" styleClass="bandeau-valeur"/>
    </VBox>
    <VBox styleClass="bandeau-cellule" HBox.hgrow="ALWAYS">
      <Label text="PROTOCOLE" styleClass="bandeau-label"/>
      <Label fx:id="valProtocole" styleClass="bandeau-valeur"/>
    </VBox>
    <VBox styleClass="bandeau-cellule" HBox.hgrow="ALWAYS">
      <Label text="CRÉÉ LE" styleClass="bandeau-label"/>
      <Label fx:id="valDateCreation" styleClass="bandeau-valeur"/>
    </VBox>
    <VBox styleClass="bandeau-cellule" HBox.hgrow="ALWAYS">
      <Label text="DERNIÈRE NUIT IMPORTÉE" styleClass="bandeau-label"/>
      <Label fx:id="valDerniereNuit" styleClass="bandeau-valeur"/>
    </VBox>
    <VBox styleClass="bandeau-cellule" HBox.hgrow="ALWAYS">
      <Label text="PASSAGES (ANNÉE)" styleClass="bandeau-label"/>
      <Label fx:id="valPassages" styleClass="bandeau-valeur"/>
    </VBox>
    <!-- Statut plateforme (#734) : le dépôt n'est possible que sur un carré VERROUILLÉ côté VigieChiro.
         C'est ici qu'on se pose la question, donc c'est ici qu'on y répond - badge posé en code
         (BadgeStatutPlateforme), avec son infobulle. -->
    <VBox fx:id="celluleStatutPlateforme" styleClass="bandeau-cellule" HBox.hgrow="ALWAYS">
      <Label text="VIGIE-CHIRO" styleClass="bandeau-label"/>
    </VBox>
  </HBox>

  <HBox alignment="CENTER_LEFT" spacing="12.0">
    <Label text="Points d'écoute" styleClass="section-titre" HBox.hgrow="ALWAYS">
      <graphic>
        <FontIcon iconLiteral="fas-map-marker-alt"/>
      </graphic>
    </Label>
    <Button text="+ Ajouter un point" styleClass="bouton-primaire" onAction="#ajouterPoint"/>
  </HBox>
  <FlowPane fx:id="cartesPoints" styleClass="cartes-points" hgap="12.0" vgap="12.0"/>
  <!-- Révélation des points rapatriés non utilisés (#1738) : la synchro ramène tous les points du carré,
       mais la fiche n'affiche par défaut que ceux qui servent. Ce lien (masqué s'il n'y a rien à révéler)
       montre/replie les autres. Libellé et visibilité pilotés en code depuis le ViewModel. -->
  <Hyperlink fx:id="lienPointsNonUtilises" styleClass="section-sous" managed="false" visible="false"/>
  <!-- Repli d'état vide (#791) : un FlowPane n'a pas de placeholder ; ce label s'affiche à sa place quand
       aucune carte de point n'est présente (visibilité liée en code à cartesPoints). -->
  <Label fx:id="lblAucunPoint" styleClass="section-sous" wrapText="true" managed="false" visible="false"
         text="Aucun point d'écoute déclaré. Cliquez « + Ajouter un point » pour en créer un."/>

  <Label text="Passages enregistrés sur ce site" styleClass="section-titre">
    <graphic>
      <FontIcon iconLiteral="fas-calendar-alt"/>
    </graphic>
  </Label>
  <TableView fx:id="tablePassages" prefHeight="320.0" VBox.vgrow="ALWAYS">
    <columns>
      <TableColumn fx:id="colDate" text="Date" prefWidth="110.0"/>
      <TableColumn fx:id="colPoint" text="Point" prefWidth="70.0"/>
      <TableColumn fx:id="colNumero" text="N° passage" prefWidth="90.0"/>
      <TableColumn fx:id="colStatut" text="Statut" prefWidth="120.0"/>
      <TableColumn fx:id="colVerdict" text="Verdict" prefWidth="120.0"/>
      <TableColumn fx:id="colEnregistreur" text="Enregistreur" prefWidth="130.0"/>
      <TableColumn fx:id="colDepose" text="Déposé le" prefWidth="120.0"/>
    </columns>
    <placeholder>
      <Label text="Aucun passage enregistré sur ce site pour le moment."/>
    </placeholder>
  </TableView>
  <Label text="Astuce : double-cliquez une ligne pour ouvrir le passage." styleClass="section-sous"/>
  <Region/>
</VBox>

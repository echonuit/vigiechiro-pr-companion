<?xml version="1.0" encoding="UTF-8"?>

<?import fr.nedjar.vigiechiro.audio.AudioView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
  M-Qualification - vérifier l'enregistrement par échantillonnage (parcours P3). Squelette
  « liste + détail » en 2 colonnes : à gauche la sélection d'écoute échantillonnée + sa
  progression, à droite le détail de la séquence + le verdict global différé (O/D/J) + commentaire.
  Pur câblage : tous les contrôles sont liés aux propriétés de SelectionEcouteViewModel (liste) et
  QualificationViewModel (verdict) par QualificationController. La vue audio (sonogramme +
  spectrogramme), la modale de personnalisation et les raccourcis clavier arrivent dans les
  tranches suivantes : ici, un emplacement réservé tient lieu de zone audio.
-->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="fr.univ_amu.iut.qualification.view.QualificationController"
           stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css, @qualification.css"
           fx:id="hoteOccupation">
  <!-- Hôte d'occupation (#1210) : voile « … en cours » pendant l'ouverture du passage (vérification +
       sélection d'écoute). -->
  <BorderPane fx:id="racine" styleClass="ecran-qualification">

  <top>
    <VBox spacing="12.0" styleClass="entete">
      <!-- Fil d'Ariane et retour : portés par le chrome (commun), via EmplacementNavigation. -->
      <!--
        Titre « Vérifier l'enregistrement par échantillonnage » retiré (#693) : redondant avec le fil
        d'Ariane. La ligne de guidance de l'écran est conservée (elle explique la démarche).
      -->
      <Label styleClass="sous-titre-page" wrapText="true"
             text="Écoutez quelques séquences réparties sur la nuit pour vous assurer que l'enregistrement est exploitable."/>

      <!-- Bandeau de rappel du passage (composant partagé bandeau-infos, #694) -->
      <HBox spacing="0.0" styleClass="bandeau-infos">
        <VBox spacing="2.0" styleClass="bandeau-cellule">
          <Label text="PASSAGE" styleClass="bandeau-label"/>
          <Label fx:id="lblTitreContexte" styleClass="bandeau-valeur"/>
        </VBox>
        <VBox spacing="2.0" styleClass="bandeau-cellule">
          <Label text="DATE / PLAGE" styleClass="bandeau-label"/>
          <Label fx:id="lblPlageHoraire" styleClass="bandeau-valeur"/>
        </VBox>
        <VBox spacing="2.0" styleClass="bandeau-cellule">
          <Label text="VOLUMÉTRIE" styleClass="bandeau-label"/>
          <Label fx:id="lblVolumetrie" styleClass="bandeau-valeur"/>
        </VBox>
        <VBox spacing="2.0" styleClass="bandeau-cellule">
          <Label text="VERDICT ACTUEL" styleClass="bandeau-label"/>
          <Label fx:id="lblVerdictActuel" styleClass="bandeau-valeur"/>
        </VBox>
        <VBox spacing="2.0" styleClass="bandeau-cellule">
          <Label text="STATUT" styleClass="bandeau-label"/>
          <Label fx:id="lblStatut" styleClass="bandeau-valeur"/>
        </VBox>
      </HBox>

      <!-- Pré-check consultatif (R13 : aucun seuil obligatoire) -->
      <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="precheck">
        <Label text="Pré-check :" styleClass="precheck-intro"/>
        <Label fx:id="feuCouverture" text="Couverture horaire" styleClass="feu"/>
        <Label fx:id="feuNombre" text="Nombre de fichiers" styleClass="feu"/>
        <Label fx:id="feuRenommage" text="Cohérence du renommage" styleClass="feu"/>
        <Label fx:id="lblAnomalie" styleClass="precheck-anomalie"
               text="⚠ Une anomalie est signalée (consultatif, non bloquant)."/>
      </HBox>
    </VBox>
  </top>

  <center>
    <SplitPane dividerPositions="0.52" styleClass="split">

      <!-- ============ Colonne gauche : sélection d'écoute ============ -->
      <VBox spacing="10.0" styleClass="colonne-liste">
        <HBox spacing="10.0" alignment="CENTER_LEFT">
          <Label fx:id="lblListeTitre" text="Sélection d'écoute" styleClass="colonne-titre">
            <graphic><FontIcon iconLiteral="fas-list-ul"/></graphic>
          </Label>
          <Region HBox.hgrow="ALWAYS"/>
          <Button fx:id="boutonPersonnaliser" text="Personnaliser…" styleClass="bouton-secondaire"
                  onAction="#personnaliser">
            <graphic><FontIcon iconLiteral="fas-sliders-h"/></graphic>
          </Button>
          <Button fx:id="boutonRegenerer" text="Régénérer" styleClass="bouton-secondaire"
                  onAction="#regenerer">
            <graphic><FontIcon iconLiteral="fas-sync-alt"/></graphic>
          </Button>
          <MenuButton fx:id="menuOutils" text="☰" styleClass="menu-actions" accessibleText="Outils : colonnes"/>
        </HBox>

        <VBox spacing="4.0">
          <ProgressBar fx:id="barreProgression" progress="0.0" maxWidth="Infinity"
                       styleClass="barre-progression"/>
          <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label fx:id="lblProgression" styleClass="progression-texte"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Aucun seuil d'écoute obligatoire" styleClass="progression-hint"/>
          </HBox>
        </VBox>

        <!-- Erreur de chargement / régénération de la sélection d'écoute (#795) : jusqu'ici avalée
             (messageProperty du ViewModel non branché) ; masquée tant qu'il n'y a pas d'erreur. -->
        <Label fx:id="lblSelectionMessage" styleClass="message-erreur" wrapText="true"
               visible="false" managed="false"/>

        <TableView fx:id="tableSequences" VBox.vgrow="ALWAYS" styleClass="table-sequences">
          <columns>
            <TableColumn fx:id="colPosition" text="N°" prefWidth="48.0"/>
            <TableColumn fx:id="colFichier" text="Fichier" prefWidth="220.0"/>
            <TableColumn fx:id="colDuree" text="Durée" prefWidth="80.0"/>
            <TableColumn fx:id="colEcoute" text="Écouté" prefWidth="70.0"/>
          </columns>
          <placeholder>
            <Label text="Aucune séquence à écouter pour l'instant." wrapText="true"/>
          </placeholder>
        </TableView>
      </VBox>

      <!-- ============ Colonne droite : détail + verdict ============ -->
      <!-- Sur une fenêtre courte, la colonne défile au lieu de laisser l'AudioView (hauteur mini)
           déborder sur le verdict. fitToHeight : l'AudioView grandit quand il y a de la place, et un
           ascenseur vertical apparaît dès que la hauteur disponible passe sous le minimum. -->
      <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="colonne-detail-scroll">
      <VBox spacing="14.0" styleClass="colonne-detail">
        <VBox spacing="4.0">
          <Label text="Séquence sélectionnée" styleClass="section-titre">
            <graphic><FontIcon iconLiteral="fas-clipboard-list"/></graphic>
          </Label>
          <VBox spacing="2.0" styleClass="seq-carte">
            <Label fx:id="lblSeqNumero" styleClass="seq-numero"/>
            <Label fx:id="lblSeqMeta" styleClass="seq-meta"/>
          </VBox>
        </VBox>

        <!-- Vue audio : sonogramme + spectrogramme + player. Composant fourni (boîte noire) ;
             la source suit la séquence courante, le marquage R10 se fait au début de lecture. -->
        <VBox spacing="4.0" VBox.vgrow="ALWAYS">
          <Label text="Vue audio (sonogramme + spectrogramme)" styleClass="section-titre">
            <graphic><FontIcon iconLiteral="fas-music"/></graphic>
          </Label>
          <AudioView fx:id="audioView" minHeight="220.0" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox spacing="6.0">
          <Label text="Verdict global du passage" styleClass="section-titre">
            <graphic><FontIcon iconLiteral="fas-gavel"/></graphic>
          </Label>
          <HBox spacing="10.0">
            <Button fx:id="boutonOk" text="OK" styleClass="verdict,verdict-ok"
                    onAction="#choisirOk" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="boutonDouteux" text="Douteux" styleClass="verdict,verdict-douteux"
                    onAction="#choisirDouteux" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="boutonAJeter" text="À jeter" styleClass="verdict,verdict-jeter"
                    onAction="#choisirAJeter" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
          </HBox>
          <Label fx:id="lblApercuR14" styleClass="apercu-r14" wrapText="true"
                 text="« À jeter » : ce passage ne pourra pas être déposé.">
            <graphic><FontIcon iconLiteral="fas-exclamation-triangle"/></graphic>
          </Label>
        </VBox>

        <VBox spacing="4.0">
          <Label text="Commentaire (optionnel)" styleClass="section-sous">
            <graphic><FontIcon iconLiteral="fas-comment-dots"/></graphic>
          </Label>
          <TextArea fx:id="champCommentaire" prefRowCount="2" wrapText="true"
                    promptText="Ex. vent fort vers 02:00, sons à vérifier ultérieurement."/>
        </VBox>

        <Label fx:id="lblAvertissement" styleClass="avertissement" wrapText="true"/>
        <Label fx:id="lblMessage" styleClass="message-erreur" wrapText="true"/>

        <!-- Légende des raccourcis clavier (#796) : câblés (gererRaccourci) mais indécouvrables sans
             cette aide visible. -->
        <Label styleClass="section-sous" wrapText="true"
               text="Raccourcis clavier : O OK · D Douteux · J À jeter · Espace écouter · Entrée enregistrer"/>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
          <!-- Confirmation de succès locale (#797) : visible une fois le verdict persisté (état ENREGISTRE),
               masquée dès qu'une modification recrée un brouillon. Complète le grisage du bouton. -->
          <Label fx:id="lblSucces" styleClass="badge, badge-succes" text="Verdict enregistré"
                 managed="false" visible="false">
            <graphic><FontIcon iconLiteral="fas-check-circle"/></graphic>
          </Label>
          <!-- Enveloppe : un Button désactivé n'affiche pas de Tooltip, on le pose sur ce StackPane (#789). -->
          <StackPane fx:id="enveloppeEnregistrer">
            <Button fx:id="boutonEnregistrer" text="Enregistrer le verdict"
                    styleClass="bouton-primaire" onAction="#enregistrer">
              <graphic><FontIcon iconLiteral="fas-save"/></graphic>
            </Button>
          </StackPane>
        </HBox>
      </VBox>
      </ScrollPane>
    </SplitPane>
  </center>
</BorderPane>
</StackPane>

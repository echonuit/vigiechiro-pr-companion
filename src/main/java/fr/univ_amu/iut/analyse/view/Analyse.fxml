<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
  M-Analyse - vue transverse « Espèces & observations » (prisme biodiversité). Écran maître-détail :
  en haut l'inventaire des espèces (regroupé Par espèce / Par carré, filtré par statut), en bas le détail
  des observations de l'espèce sélectionnée, à travers les passages, avec « ouvrir le passage ».
  Pur câblage : le controller lie tables, barre de regroupement/filtre et navigation à l'AnalyseViewModel.
-->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="fr.univ_amu.iut.analyse.view.AnalyseController"
           stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css, @analyse.css"
           fx:id="hoteOccupation">
  <!-- Hôte d'occupation (#1208) : IndicateurOccupation superpose son voile « … en cours » par-dessus
       ce contenu pendant le chargement des observations, hors du fil JavaFX. -->
  <VBox styleClass="ecran-analyse" spacing="10.0">

  <Label fx:id="lblResume" styleClass="analyse-resume"/>

  <!-- Onglets de vues mémorisées « à la Notion » (#623) : un onglet par combinaison de filtres enregistrée.
       Rempli en code par le composant partagé GestionnaireVues (le controller le construit). -->
  <FlowPane fx:id="barreOnglets" hgap="6.0" vgap="6.0" alignment="CENTER_LEFT" styleClass="barre-onglets"/>

  <!-- Barre de filtres « à la Notion » (#537, étape 6) : le pivot de regroupement (espèce ↔ carré), la
       recherche texte permanente, le bouton « + Filtre » (statut, taxon parent) et les puces des filtres
       actifs, puis les actions carte/export. Le regroupement n'est PAS un filtre : il change l'agrégation,
       pas le sous-ensemble affiché, d'où sa place à part (contrôle fixe). -->
  <HBox spacing="8.0" alignment="CENTER_LEFT" styleClass="barre-filtres">
    <ComboBox fx:id="choixRegroupement" accessibleText="Regrouper par espèce ou par carré"/>
    <TextField fx:id="champRecherche" promptText="Rechercher (espèce, carré…)"
               accessibleText="Rechercher dans l'inventaire" prefWidth="200.0"/>
    <MenuButton fx:id="menuAjoutFiltre" text="+ Filtre" styleClass="menu-ajout-filtre"
                accessibleText="Ajouter un filtre"/>
    <!-- hgrow + maxWidth : les puces occupent la largeur restante et s'alignent horizontalement (sinon le
         FlowPane se limite à sa largeur préférée et les empile). Carte/Exporter s'ancrent à droite. -->
    <FlowPane fx:id="pucesFiltres" hgap="6.0" vgap="6.0" alignment="CENTER_LEFT"
              HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    <Button fx:id="boutonCarte" text="Carte" onAction="#basculerCarte">
      <graphic>
        <FontIcon fx:id="iconeCarte" iconLiteral="fas-map"/>
      </graphic>
    </Button>
    <Button fx:id="boutonExporter" text="Exporter…" onAction="#exporter">
      <graphic>
        <FontIcon iconLiteral="fas-file-export"/>
      </graphic>
    </Button>
    <MenuButton fx:id="menuOutils" styleClass="menu-actions" accessibleText="Outils : colonnes">
      <graphic>
        <FontIcon iconLiteral="fas-bars"/>
      </graphic>
    </MenuButton>
  </HBox>

  <SplitPane fx:id="separateur" orientation="VERTICAL" dividerPositions="0.58" VBox.vgrow="ALWAYS">

    <!-- Maître : inventaire (Par espèce / Par carré) ou carte de répartition (bascule). -->
    <StackPane>
      <TableView fx:id="tableEspeces">
        <columns>
          <TableColumn fx:id="colEspece" text="Espèce" prefWidth="240.0"/>
          <TableColumn fx:id="colGroupe" text="Taxon parent" prefWidth="140.0"/>
          <TableColumn fx:id="colDetections" text="Détections" prefWidth="95.0"/>
          <TableColumn fx:id="colPassages" text="Passages" prefWidth="90.0"/>
          <TableColumn fx:id="colCarres" text="Carrés" prefWidth="80.0"/>
          <TableColumn fx:id="colPoints" text="Points" prefWidth="80.0"/>
          <TableColumn fx:id="colPeriode" text="Période" prefWidth="110.0"/>
        </columns>
      </TableView>
      <TableView fx:id="tableCarres">
        <columns>
          <TableColumn fx:id="colCarre" text="Carré" prefWidth="120.0"/>
          <TableColumn fx:id="colSite" text="Site" prefWidth="240.0"/>
          <TableColumn fx:id="colRichesse" text="Richesse (espèces)" prefWidth="150.0"/>
          <TableColumn fx:id="colDetectionsCarre" text="Détections" prefWidth="100.0"/>
          <TableColumn fx:id="colPeriodeCarre" text="Période" prefWidth="110.0"/>
        </columns>
      </TableView>
      <!-- Carte de répartition : le controller y ajoute le composant CarteSites + la légende (en code,
           car CarteSites n'est pas un nœud FXML). Masquée tant que la bascule « 🗺️ Carte » n'est pas active. -->
      <StackPane fx:id="zoneCarte"/>
    </StackPane>

    <!-- Détail : observations de l'espèce sélectionnée, à travers les passages.
         Retiré du SplitPane hors regroupement Par espèce (le contrôleur gère l'ajout/retrait). -->
    <VBox fx:id="panneauDetail" styleClass="analyse-detail" spacing="8.0">
      <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label fx:id="lblDetailTitre" styleClass="analyse-detail-titre"/>
        <Region HBox.hgrow="ALWAYS"/>
        <!-- Enveloppes : un Button désactivé n'affiche pas de Tooltip, on le pose sur ce StackPane (#789). -->
        <StackPane fx:id="enveloppeEcouter">
          <Button fx:id="boutonEcouter" text="Écouter / valider" onAction="#ecouterValider">
            <graphic>
              <FontIcon iconLiteral="fas-headphones"/>
            </graphic>
          </Button>
        </StackPane>
        <StackPane fx:id="enveloppeOuvrirPassage">
          <Button fx:id="boutonOuvrirPassage" text="Ouvrir le passage" onAction="#ouvrirPassage">
            <graphic>
              <FontIcon iconLiteral="fas-arrow-right"/>
            </graphic>
          </Button>
        </StackPane>
      </HBox>
      <StackPane VBox.vgrow="ALWAYS">
        <TableView fx:id="tableObservations">
          <columns>
            <TableColumn fx:id="colObsPassage" text="Passage" prefWidth="160.0"/>
            <TableColumn fx:id="colObsCarre" text="Carré" prefWidth="90.0"/>
            <TableColumn fx:id="colObsRichesse" text="Espèces du carré" prefWidth="115.0"/>
            <TableColumn fx:id="colObsPoint" text="Point" prefWidth="70.0"/>
            <TableColumn fx:id="colObsTadarida" text="Proposition Tadarida" prefWidth="180.0"/>
            <TableColumn fx:id="colObsObservateur" text="Votre taxon" prefWidth="150.0"/>
            <TableColumn fx:id="colObsStatut" text="Statut" prefWidth="110.0"/>
          </columns>
        </TableView>
        <Label fx:id="lblDetailVide" styleClass="analyse-detail-vide" wrapText="true"
               text="Sélectionnez une espèce dans l'inventaire (regroupement « Par espèce ») pour lister ses observations à travers les passages."/>
      </StackPane>
      <Label text="Astuce : double-cliquez une ligne pour ouvrir la fiche de l'espèce." styleClass="section-sous"/>
    </VBox>

  </SplitPane>

  <!-- Bandeau de retour d'opération (export, échec de chargement, action refusée), mutualisé avec
       Sons & validation : style dans commun/view/design.css, câblage dans commun/view/BandeauRetour. -->
  <HBox fx:id="bandeauRetour" styleClass="bandeau-retour" alignment="CENTER_LEFT" spacing="10.0">
    <Label fx:id="lblRetour" wrapText="true" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    <Button fx:id="btnFermerRetour" styleClass="fermer-retour" accessibleText="Fermer le message">
      <graphic>
        <FontIcon iconLiteral="fas-times"/>
      </graphic>
    </Button>
  </HBox>
  <Label fx:id="lblMessage" styleClass="analyse-vide" wrapText="true"/>
  </VBox>
</StackPane>

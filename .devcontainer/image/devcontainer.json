{
    // Recette de build de l'image pré-buildée (utilisée UNIQUEMENT par la CI,
    // workflow .github/workflows/devcontainer-image.yml). Elle bake une fois pour
    // toutes les features (dont le feature java/SDKMAN) dans une image publiée sur
    // GHCR. Les étudiants ne consomment QUE cette image via .devcontainer/devcontainer.json
    // ("image": ghcr.io/...), donc plus aucun appel SDKMAN/noVNC au démarrage de
    // leur Codespace : fini les échecs de build sur HTTP 504 SDKMAN intermittents.
    //
    // Ce fichier ne contient QUE le couple build + features. Tout le reste
    // (forwardPorts, onCreateCommand, customizations, remoteUser) vit dans le
    // devcontainer.json étudiant pour ne pas être baké en double dans la metadata.
    "name": "SAÉ 2.01 - recette image pré-buildée (CI only)",
    "build": {
        "dockerfile": "../Dockerfile",
        "context": ".."
    },
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true,
            "installOhMyZsh": true,
            "upgradePackages": true,
            "username": "vscode",
            "uid": "1000",
            "gid": "1000"
        },
        "ghcr.io/devcontainers/features/java:1": {
            "version": "25-tem",
            "installMaven": "false",
            "installGradle": "false"
        },
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/desktop-lite:1": {
            "password": "vscode",
            "webPort": "6080",
            "vncPort": "5901"
        }
    }
}

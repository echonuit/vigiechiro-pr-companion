{
    "name": "VigieChiro Companion",
    // Le conteneur se construit à partir du Dockerfile voisin et des features
    // ci-dessous. Il a un temps consommé une image pré-buildée publiée sur GHCR
    // par un workflow dédié ; ce dispositif a été retiré (#2388) parce qu'il ne
    // fonctionnait plus : le workflow se déclenchait sur une branche absente de
    // ce dépôt, l'image n'a donc jamais été publiée sous cette organisation, et
    // le conteneur ne pouvait plus se construire du tout. Un build local est
    // plus lent au premier démarrage, mais il ne dépend que de sources vivantes.
    "build": {
        "dockerfile": "Dockerfile",
        "context": "."
    },
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true,
            "installOhMyZsh": true,
            "upgradePackages": true,
            "username": "vscode",
            "uid": "1000",
            "gid": "1000"
        },
        // JDK 25 standard, sans Maven ni Gradle : tout passe par ./mvnw.
        "ghcr.io/devcontainers/features/java:1": {
            "version": "25-tem",
            "installMaven": "false",
            "installGradle": "false"
        },
        "ghcr.io/devcontainers/features/github-cli:1": {},
        // Bureau léger + noVNC (port 6080) pour lancer l'application JavaFX
        // depuis un navigateur quand on travaille sans affichage local.
        "ghcr.io/devcontainers/features/desktop-lite:1": {
            "password": "vscode",
            "webPort": "6080",
            "vncPort": "5901"
        }
    },
    "forwardPorts": [6080, 5901],
    // onCreateCommand : pré-télécharge les dépendances (dependency:go-offline)
    // pour que le LSP Java et le premier build ne soient pas bloqués par le
    // réseau. bash -lc pour charger SDKMAN. On NE compile PAS au démarrage
    // (pas de test-compile) : un target/ compilé ici peut devenir périmé après
    // une régénération de branche ou un pull et faire mentir « Nothing to
    // compile » (module-info.class obsolète -> erreurs JPMS au javafx:run).
    // jdt.ls indexe de son côté, donc les CodeLens "Run | Debug" apparaissent
    // quand même, juste un peu plus tard. Réflexe en cas de doute : ./mvnw clean.
    // `git config merge.ours.driver true` active le driver `merge=ours` declare
    // dans .gitattributes pour les apercus de captures (.github/assets/apercu-*.png) :
    // evite les conflits binaires impossibles a resoudre quand on merge `main`.
    "onCreateCommand": "git config merge.ours.driver true; bash -lc './mvnw -q dependency:go-offline || true' && gh repo set-default \"$(git remote get-url origin | sed 's|.*github.com[:/]||' | sed 's|\\.git$||')\" 2>/dev/null || true",
    "customizations": {
        "vscode": {
            "settings": {
                "java.jdt.ls.java.home": "/usr/local/sdkman/candidates/java/current",
                "terminal.integrated.profiles.linux": {
                    "zsh": { "path": "zsh" }
                },
                "terminal.integrated.defaultProfile.linux": "zsh",
                "redhat.telemetry.enabled": false
            },
            "extensions": [
                "redhat.java",
                "redhat.vscode-xml",
                "vscjava.vscode-java-debug",
                "vscjava.vscode-java-test",
                "vscjava.vscode-maven",
                "vscjava.vscode-java-dependency",
                "eamodio.gitlens",
                "GitHub.copilot-chat"
            ]
        }
    },
    "remoteUser": "vscode"
}
